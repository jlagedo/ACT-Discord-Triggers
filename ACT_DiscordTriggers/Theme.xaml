<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--
        ============================================================
        Palette — light, with a single blue accent. Grounded in
        Windows Fluent 2: surfaces sit flat behind hairline-bordered
        cards (no floating shadow), the page carries a faint cool
        tint and the cards are pure white.
        ============================================================
    -->
    <Color x:Key="SurfaceColor">#EFF4FA</Color>
    <Color x:Key="AccentColor">#2F6FE0</Color>

    <SolidColorBrush x:Key="Surface" Color="#EFF4FA" />
    <SolidColorBrush x:Key="Rail" Color="#FFFFFF" />
    <SolidColorBrush x:Key="Card" Color="#FFFFFF" />
    <SolidColorBrush x:Key="CardBorder" Color="#DEE7F2" />
    <SolidColorBrush x:Key="Divider" Color="#E7EDF5" />

    <SolidColorBrush x:Key="Accent" Color="#2F6FE0" />
    <SolidColorBrush x:Key="AccentHover" Color="#2A63C8" />
    <SolidColorBrush x:Key="AccentPressed" Color="#234FA3" />
    <SolidColorBrush x:Key="AccentSoft" Color="#E9F1FD" />
    <SolidColorBrush x:Key="AccentSoftHover" Color="#DBE8FB" />

    <SolidColorBrush x:Key="TextPrimary" Color="#1C2A3A" />
    <SolidColorBrush x:Key="TextSecondary" Color="#647689" />
    <SolidColorBrush x:Key="TextMuted" Color="#8A99AB" />
    <SolidColorBrush x:Key="OnAccent" Color="#FFFFFF" />

    <SolidColorBrush x:Key="FieldBg" Color="#FFFFFF" />
    <SolidColorBrush x:Key="FieldBorder" Color="#CCD9E8" />
    <!--  Fluent inputs carry a stronger stroke on the bottom edge that turns to a 2px accent underline on focus.  -->
    <SolidColorBrush x:Key="FieldStrongBorder" Color="#9FB0C2" />
    <!--  Neutral subtle hover for default buttons and nav items (Fluent uses a quiet fill, not an accent tint).  -->
    <SolidColorBrush x:Key="ControlHover" Color="#E7EDF4" />
    <SolidColorBrush x:Key="ControlPressed" Color="#DDE5EF" />
    <SolidColorBrush x:Key="Track" Color="#D9E2EF" />
    <SolidColorBrush x:Key="DisabledBg" Color="#F1F4F8" />
    <SolidColorBrush x:Key="DisabledText" Color="#A9B4C0" />

    <!--  Connection status — calm green when live, muted red when not.  -->
    <SolidColorBrush x:Key="StatusOnline" Color="#27AE60" />
    <SolidColorBrush x:Key="StatusOffline" Color="#CF5B4E" />

    <!--  Elevation reserved for transient surfaces (combo flyout) — cards stay flat in Fluent.  -->
    <DropShadowEffect
        x:Key="FlyoutShadow"
        BlurRadius="14"
        Direction="270"
        Opacity="0.16"
        ShadowDepth="3"
        Color="#1C2A3A" />

