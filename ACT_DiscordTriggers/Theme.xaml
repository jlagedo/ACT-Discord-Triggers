<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <!--
        ============================================================
        Palette — light, with a single blue accent. Grounded in
        Windows Fluent 2: surfaces sit flat behind hairline-bordered
        cards (no floating shadow), the page carries a faint cool
        tint and the cards are pure white.
        ============================================================
    -->
    <Color x:Key="SurfaceColor">#EFF4FA</Color>
    <Color x:Key="AccentColor">#2F6FE0</Color>

    <SolidColorBrush x:Key="Surface" Color="#EFF4FA" />
    <SolidColorBrush x:Key="Rail" Color="#FFFFFF" />
    <SolidColorBrush x:Key="Card" Color="#FFFFFF" />
    <SolidColorBrush x:Key="CardBorder" Color="#DEE7F2" />
    <SolidColorBrush x:Key="Divider" Color="#E7EDF5" />

    <SolidColorBrush x:Key="Accent" Color="#2F6FE0" />
    <SolidColorBrush x:Key="AccentHover" Color="#2A63C8" />
    <SolidColorBrush x:Key="AccentPressed" Color="#234FA3" />
    <SolidColorBrush x:Key="AccentSoft" Color="#E9F1FD" />
    <SolidColorBrush x:Key="AccentSoftHover" Color="#DBE8FB" />

    <SolidColorBrush x:Key="TextPrimary" Color="#1C2A3A" />
    <SolidColorBrush x:Key="TextSecondary" Color="#647689" />
    <SolidColorBrush x:Key="TextMuted" Color="#8A99AB" />
    <SolidColorBrush x:Key="OnAccent" Color="#FFFFFF" />

    <SolidColorBrush x:Key="FieldBg" Color="#FFFFFF" />
    <SolidColorBrush x:Key="FieldBorder" Color="#CCD9E8" />
    <!--  Fluent inputs carry a stronger stroke on the bottom edge that turns to a 2px accent underline on focus.  -->
    <SolidColorBrush x:Key="FieldStrongBorder" Color="#9FB0C2" />
    <!--  Neutral subtle hover for default buttons and nav items (Fluent uses a quiet fill, not an accent tint).  -->
    <SolidColorBrush x:Key="ControlHover" Color="#E7EDF4" />
    <SolidColorBrush x:Key="ControlPressed" Color="#DDE5EF" />
    <SolidColorBrush x:Key="Track" Color="#D9E2EF" />
    <SolidColorBrush x:Key="DisabledBg" Color="#F1F4F8" />
    <SolidColorBrush x:Key="DisabledText" Color="#A9B4C0" />

    <!--  Connection status — calm green when live, muted red when not.  -->
    <SolidColorBrush x:Key="StatusOnline" Color="#27AE60" />
    <SolidColorBrush x:Key="StatusOffline" Color="#CF5B4E" />

    <!--  Elevation reserved for transient surfaces (combo flyout) — cards stay flat in Fluent.  -->
    <DropShadowEffect
        x:Key="FlyoutShadow"
        BlurRadius="14"
        Direction="270"
        Opacity="0.16"
        ShadowDepth="3"
        Color="#1C2A3A" />

    <!--
        ============================================================
        System icons — Segoe Fluent Icons glyphs (the Windows 11
        symbol font). Each key is the glyph's Private-Use code point;
        rendered as text through the IconGlyph style / inline TextBlocks.
        ============================================================
    -->
    <FontFamily x:Key="IconFont">Segoe Fluent Icons</FontFamily>

    <sys:String x:Key="Icon.General">&#xE713;</sys:String>
    <sys:String x:Key="Icon.Sound">&#xE767;</sys:String>
    <sys:String x:Key="Icon.Info">&#xE946;</sys:String>
    <sys:String x:Key="Icon.Key">&#xE980;</sys:String>
    <sys:String x:Key="Icon.PlugConnected">&#xE703;</sys:String>
    <sys:String x:Key="Icon.Chat">&#xE8BD;</sys:String>
    <sys:String x:Key="Icon.AutoConnect">&#xE895;</sys:String>
    <sys:String x:Key="Icon.Server">&#xEC05;</sys:String>
    <sys:String x:Key="Icon.Channel">&#xE7F6;</sys:String>
    <sys:String x:Key="Icon.Voice">&#xE720;</sys:String>
    <sys:String x:Key="Icon.Speed">&#xEC49;</sys:String>
    <sys:String x:Key="Icon.Wand">&#xE794;</sys:String>
    <sys:String x:Key="Icon.Level">&#xE9E9;</sys:String>
    <sys:String x:Key="Icon.Quality">&#xE93E;</sys:String>
    <sys:String x:Key="Icon.Folder">&#xE8B7;</sys:String>
    <sys:String x:Key="Icon.Bug">&#xEBE8;</sys:String>
    <sys:String x:Key="Icon.Guide">&#xE8F1;</sys:String>
    <sys:String x:Key="Icon.Open">&#xE8A7;</sys:String>

    <!--  ONNX TTS glyphs — engine cards, quality/voice rows, install-state, test/help, Advanced.  -->
    <sys:String x:Key="Icon.Sparkle">&#xEB78;</sys:String>
    <sys:String x:Key="Icon.Desktop">&#xE7F4;</sys:String>
    <sys:String x:Key="Icon.TopSpeed">&#xEC4A;</sys:String>
    <sys:String x:Key="Icon.Download">&#xE896;</sys:String>
    <sys:String x:Key="Icon.CheckCircle">&#xEC61;</sys:String>
    <sys:String x:Key="Icon.PlayCircle">&#xE768;</sys:String>
    <sys:String x:Key="Icon.Help">&#xE897;</sys:String>
    <sys:String x:Key="Icon.Chevron">&#xE76C;</sys:String>
    <sys:String x:Key="Icon.ChevronDown">&#xE70D;</sys:String>
    <sys:String x:Key="Icon.Star">&#xE735;</sys:String>

    <!--  Settings-card / nav row icon — Segoe Fluent Icons glyph, calm neutral.  -->
    <Style x:Key="IconGlyph" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource IconFont}" />
        <Setter Property="FontSize" Value="16" />
        <Setter Property="Foreground" Value="{StaticResource TextSecondary}" />
        <Setter Property="HorizontalAlignment" Value="Center" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <!--
        ============================================================
        Typography roles — Fluent type ramp (Segoe UI Variable).
        ============================================================
    -->

    <!--  Section header — BodyStrong, primary. Groups a stack of setting cards.  -->
    <Style x:Key="SectionHeader" TargetType="TextBlock">
        <Setter Property="FontSize" Value="14" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
        <Setter Property="Margin" Value="2,18,0,8" />
    </Style>

    <!--  Card title — Body, primary (14/20). The label for a single setting.  -->
    <Style x:Key="CardTitle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="14" />
        <Setter Property="LineHeight" Value="20" />
        <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
        <Setter Property="TextWrapping" Value="Wrap" />
    </Style>

    <!--  Card description — Caption, secondary (Small optical, 12/16). Sits under a card title.  -->
    <Style x:Key="CardDesc" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="Segoe UI Variable Small, Segoe UI" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="LineHeight" Value="16" />
        <Setter Property="Foreground" Value="{StaticResource TextSecondary}" />
        <Setter Property="Margin" Value="0,2,0,0" />
        <Setter Property="TextWrapping" Value="Wrap" />
    </Style>

    <!--  Caption — muted (Small optical, 12/16).  -->
    <Style x:Key="Caption" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="Segoe UI Variable Small, Segoe UI" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="LineHeight" Value="16" />
        <Setter Property="Foreground" Value="{StaticResource TextMuted}" />
    </Style>

    <!--
        ============================================================
        SettingsCard — a Fluent settings row: [icon] title/description
        … control. Built on HeaderedContentControl (GAC type, styled
        only): Header = title (string) or a title+description panel;
        Tag = the icon Geometry; Content = the control on the right.
        ============================================================
    -->
    <Style x:Key="SettingsCard" TargetType="HeaderedContentControl">
        <Setter Property="Margin" Value="0,0,0,4" />
        <Setter Property="MinHeight" Value="50" />
        <Setter Property="Padding" Value="14,9" />
        <Setter Property="HorizontalContentAlignment" Value="Right" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="HeaderedContentControl">
                    <Border
                        Background="{StaticResource Card}"
                        BorderBrush="{StaticResource CardBorder}"
                        BorderThickness="1"
                        CornerRadius="4">
                        <Grid Margin="{TemplateBinding Padding}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock
                                x:Name="icon"
                                Grid.Column="0"
                                Margin="2,0,14,0"
                                Style="{StaticResource IconGlyph}"
                                Text="{TemplateBinding Tag}" />
                            <ContentPresenter
                                Grid.Column="1"
                                VerticalAlignment="Center"
                                ContentSource="Header"
                                TextElement.FontSize="14"
                                TextElement.Foreground="{StaticResource TextPrimary}" />
                            <ContentPresenter
                                Grid.Column="2"
                                Margin="16,0,0,0"
                                HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <!--  Sub-rows pass no icon; reserve its space (Hidden) so titles still align.  -->
                        <Trigger Property="Tag" Value="{x:Null}">
                            <Setter TargetName="icon" Property="Visibility" Value="Hidden" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!--
        ============================================================
        Buttons — implicit = standard (neutral fill); PrimaryButton =
        accent fill. Fluent radius (4) and a quiet neutral hover.
        ============================================================
    -->
    <Style TargetType="Button">
        <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
        <Setter Property="Background" Value="{StaticResource FieldBg}" />
        <Setter Property="BorderBrush" Value="{StaticResource FieldBorder}" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Padding" Value="14,7" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border
                        x:Name="bd"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="4">
                        <ContentPresenter
                            Margin="{TemplateBinding Padding}"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bd" Property="Background" Value="{StaticResource ControlHover}" />
                        </Trigger>
                        <Trigger Property="IsKeyboardFocused" Value="True">
                            <Setter TargetName="bd" Property="BorderBrush" Value="{StaticResource Accent}" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="bd" Property="Background" Value="{StaticResource ControlPressed}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="bd" Property="Background" Value="{StaticResource DisabledBg}" />
                            <Setter TargetName="bd" Property="BorderBrush" Value="{StaticResource DisabledBg}" />
                            <Setter Property="Foreground" Value="{StaticResource DisabledText}" />
                            <Setter Property="Cursor" Value="Arrow" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style
        x:Key="PrimaryButton"
        BasedOn="{StaticResource {x:Type Button}}"
        TargetType="Button">
        <Setter Property="Foreground" Value="{StaticResource OnAccent}" />
        <Setter Property="Background" Value="{StaticResource Accent}" />
        <Setter Property="BorderBrush" Value="{StaticResource Accent}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border
                        x:Name="bd"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="4">
                        <ContentPresenter
                            Margin="{TemplateBinding Padding}"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            TextElement.Foreground="{TemplateBinding Foreground}" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bd" Property="Background" Value="{StaticResource AccentHover}" />
                            <Setter TargetName="bd" Property="BorderBrush" Value="{StaticResource AccentHover}" />
                        </Trigger>
                        <Trigger Property="IsKeyboardFocused" Value="True">
                            <Setter TargetName="bd" Property="BorderBrush" Value="{StaticResource AccentPressed}" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="bd" Property="Background" Value="{StaticResource AccentPressed}" />
                            <Setter TargetName="bd" Property="BorderBrush" Value="{StaticResource AccentPressed}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="bd" Property="Background" Value="{StaticResource DisabledBg}" />
                            <Setter TargetName="bd" Property="BorderBrush" Value="{StaticResource DisabledBg}" />
                            <Setter Property="Foreground" Value="{StaticResource DisabledText}" />
                            <Setter Property="Cursor" Value="Arrow" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!--
        ============================================================
        Text inputs — Fluent field: hairline box with a stronger
        bottom edge that becomes a 2px accent underline on focus.
        ============================================================
    -->
    <Style TargetType="TextBox">
        <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
        <Setter Property="CaretBrush" Value="{StaticResource Accent}" />
        <Setter Property="SelectionBrush" Value="{StaticResource Accent}" />
        <Setter Property="Padding" Value="9,6" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TextBox">
                    <Grid>
                        <Border
                            x:Name="bd"
                            Background="{StaticResource FieldBg}"
                            BorderBrush="{StaticResource FieldBorder}"
                            BorderThickness="1"
                            CornerRadius="4">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}" />
                        </Border>
                        <Border
                            x:Name="underline"
                            Height="2"
                            VerticalAlignment="Bottom"
                            Background="{StaticResource Accent}"
                            CornerRadius="0,0,4,4"
                            Visibility="Collapsed" />
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bd" Property="BorderBrush" Value="{StaticResource FieldStrongBorder}" />
                        </Trigger>
                        <Trigger Property="IsKeyboardFocused" Value="True">
                            <Setter TargetName="bd" Property="BorderBrush" Value="{StaticResource FieldStrongBorder}" />
                            <Setter TargetName="underline" Property="Visibility" Value="Visible" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="PasswordBox">
        <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
        <Setter Property="CaretBrush" Value="{StaticResource Accent}" />
        <Setter Property="SelectionBrush" Value="{StaticResource Accent}" />
        <Setter Property="Padding" Value="9,6" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="PasswordBox">
                    <Grid>
                        <Border
                            x:Name="bd"
                            Background="{StaticResource FieldBg}"
                            BorderBrush="{StaticResource FieldBorder}"
                            BorderThickness="1"
                            CornerRadius="4">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}" />
                        </Border>
                        <Border
                            x:Name="underline"
                            Height="2"
                            VerticalAlignment="Bottom"
                            Background="{StaticResource Accent}"
                            CornerRadius="0,0,4,4"
                            Visibility="Collapsed" />
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bd" Property="BorderBrush" Value="{StaticResource FieldStrongBorder}" />
                        </Trigger>
                        <Trigger Property="IsKeyboardFocused" Value="True">
                            <Setter TargetName="bd" Property="BorderBrush" Value="{StaticResource FieldStrongBorder}" />
                            <Setter TargetName="underline" Property="Visibility" Value="Visible" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!--
        ============================================================
        Thin scrollbar — shared by ScrollViewer, ComboBox popup, ListView.
        ============================================================
    -->
    <Style x:Key="ScrollThumb" TargetType="Thumb">
        <Setter Property="OverridesDefaultStyle" Value="True" />
        <Setter Property="IsTabStop" Value="False" />
        <Setter Property="Foreground" Value="#C2D0E0" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Thumb">
                    <Border
                        Padding="0"
                        Background="{TemplateBinding Foreground}"
                        CornerRadius="4" />
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Foreground" Value="#9FB3CC" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style TargetType="ScrollBar">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Width" Value="10" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ScrollBar">
                    <Grid Background="Transparent">
                        <Track x:Name="PART_Track" IsDirectionReversed="True">
                            <Track.DecreaseRepeatButton>
                                <RepeatButton
                                    Command="ScrollBar.PageUpCommand"
                                    Focusable="False"
                                    Opacity="0">
                                    <RepeatButton.Template>
                                        <ControlTemplate TargetType="RepeatButton">
                                            <Border Background="Transparent" />
                                        </ControlTemplate>
                                    </RepeatButton.Template>
                                </RepeatButton>
                            </Track.DecreaseRepeatButton>
                            <Track.Thumb>
                                <Thumb Margin="2,0" Style="{StaticResource ScrollThumb}" />
                            </Track.Thumb>
                            <Track.IncreaseRepeatButton>
                                <RepeatButton
                                    Command="ScrollBar.PageDownCommand"
                                    Focusable="False"
                                    Opacity="0">
                                    <RepeatButton.Template>
                                        <ControlTemplate TargetType="RepeatButton">
                                            <Border Background="Transparent" />
                                        </ControlTemplate>
                                    </RepeatButton.Template>
                                </RepeatButton>
                            </Track.IncreaseRepeatButton>
                        </Track>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="Orientation" Value="Horizontal">
                <Setter Property="Width" Value="Auto" />
                <Setter Property="Height" Value="10" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ScrollBar">
                            <Grid Background="Transparent">
                                <Track x:Name="PART_Track">
                                    <Track.DecreaseRepeatButton>
                                        <RepeatButton
                                            Command="ScrollBar.PageLeftCommand"
                                            Focusable="False"
                                            Opacity="0">
                                            <RepeatButton.Template>
                                                <ControlTemplate TargetType="RepeatButton">
                                                    <Border Background="Transparent" />
                                                </ControlTemplate>
                                            </RepeatButton.Template>
                                        </RepeatButton>
                                    </Track.DecreaseRepeatButton>
                                    <Track.Thumb>
                                        <Thumb Margin="0,2" Style="{StaticResource ScrollThumb}" />
                                    </Track.Thumb>
                                    <Track.IncreaseRepeatButton>
                                        <RepeatButton
                                            Command="ScrollBar.PageRightCommand"
                                            Focusable="False"
                                            Opacity="0">
                                            <RepeatButton.Template>
                                                <ControlTemplate TargetType="RepeatButton">
                                                    <Border Background="Transparent" />
                                                </ControlTemplate>
                                            </RepeatButton.Template>
                                        </RepeatButton>
                                    </Track.IncreaseRepeatButton>
                                </Track>
                            </Grid>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!--
        ============================================================
        ComboBox — Fluent field with focus underline + elevated flyout.
        ============================================================
    -->
    <Style x:Key="ComboItem" TargetType="ComboBoxItem">
        <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
        <Setter Property="Padding" Value="10,7" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ComboBoxItem">
                    <Border
                        x:Name="bd"
                        Padding="{TemplateBinding Padding}"
                        Background="Transparent"
                        CornerRadius="4">
                        <ContentPresenter />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bd" Property="Background" Value="{StaticResource ControlHover}" />
                        </Trigger>
                        <Trigger Property="IsHighlighted" Value="True">
                            <Setter TargetName="bd" Property="Background" Value="{StaticResource ControlHover}" />
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="bd" Property="Background" Value="{StaticResource AccentSoft}" />
                            <Setter Property="Foreground" Value="{StaticResource Accent}" />
                            <Setter Property="FontWeight" Value="SemiBold" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="ComboBox">
        <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
        <Setter Property="Height" Value="32" />
        <Setter Property="ItemContainerStyle" Value="{StaticResource ComboItem}" />
        <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ComboBox">
                    <Grid>
                        <ToggleButton
                            x:Name="tb"
                            ClickMode="Press"
                            Focusable="False"
                            IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
                            <ToggleButton.Template>
                                <ControlTemplate TargetType="ToggleButton">
                                    <Grid>
                                        <Border
                                            x:Name="bd"
                                            Background="{StaticResource FieldBg}"
                                            BorderBrush="{StaticResource FieldBorder}"
                                            BorderThickness="1"
                                            CornerRadius="4">
                                            <TextBlock
                                                x:Name="arrow"
                                                Margin="0,0,12,0"
                                                HorizontalAlignment="Right"
                                                VerticalAlignment="Center"
                                                FontFamily="{StaticResource IconFont}"
                                                FontSize="16"
                                                Foreground="{StaticResource TextSecondary}"
                                                Text="{StaticResource Icon.ChevronDown}" />
                                        </Border>
                                        <Border
                                            x:Name="underline"
                                            Height="2"
                                            VerticalAlignment="Bottom"
                                            Background="{StaticResource Accent}"
                                            CornerRadius="0,0,4,4"
                                            Visibility="Collapsed" />
                                    </Grid>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="bd" Property="BorderBrush" Value="{StaticResource FieldStrongBorder}" />
                                        </Trigger>
                                        <Trigger Property="IsChecked" Value="True">
                                            <Setter TargetName="bd" Property="BorderBrush" Value="{StaticResource FieldStrongBorder}" />
                                            <Setter TargetName="arrow" Property="Foreground" Value="{StaticResource Accent}" />
                                            <Setter TargetName="underline" Property="Visibility" Value="Visible" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </ToggleButton.Template>
                        </ToggleButton>
                        <ContentPresenter
                            Margin="11,0,32,0"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Center"
                            Content="{TemplateBinding SelectionBoxItem}"
                            ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                            IsHitTestVisible="False" />
                        <Popup
                            x:Name="PART_Popup"
                            AllowsTransparency="True"
                            Focusable="False"
                            IsOpen="{TemplateBinding IsDropDownOpen}"
                            Placement="Bottom"
                            PopupAnimation="Fade">
                            <Border
                                MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}"
                                MaxHeight="{TemplateBinding MaxDropDownHeight}"
                                Margin="0,4,0,6"
                                Padding="4"
                                Background="{StaticResource Card}"
                                BorderBrush="{StaticResource CardBorder}"
                                BorderThickness="1"
                                CornerRadius="8"
                                Effect="{StaticResource FlyoutShadow}">
                                <ScrollViewer>
                                    <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Contained" />
                                </ScrollViewer>
                            </Border>
                        </Popup>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Foreground" Value="{StaticResource DisabledText}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!--
        ============================================================
        ToggleSwitch — Fluent switch built on CheckBox (no content;
        the label lives in the settings-card header).
        ============================================================
    -->
    <Style x:Key="ToggleSwitch" TargetType="CheckBox">
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="CheckBox">
                    <Border
                        x:Name="track"
                        Width="40"
                        Height="20"
                        Background="Transparent"
                        BorderBrush="{StaticResource FieldStrongBorder}"
                        BorderThickness="1"
                        CornerRadius="10">
                        <Ellipse
                            x:Name="knob"
                            Width="12"
                            Height="12"
                            Margin="4,0,0,0"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Center"
                            Fill="{StaticResource TextSecondary}" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="track" Property="BorderBrush" Value="{StaticResource TextSecondary}" />
                        </Trigger>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="track" Property="Background" Value="{StaticResource Accent}" />
                            <Setter TargetName="track" Property="BorderBrush" Value="{StaticResource Accent}" />
                            <Setter TargetName="knob" Property="Fill" Value="{StaticResource OnAccent}" />
                            <Setter TargetName="knob" Property="HorizontalAlignment" Value="Right" />
                            <Setter TargetName="knob" Property="Margin" Value="0,0,4,0" />
                        </Trigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsChecked" Value="True" />
                                <Condition Property="IsMouseOver" Value="True" />
                            </MultiTrigger.Conditions>
                            <Setter TargetName="track" Property="Background" Value="{StaticResource AccentHover}" />
                            <Setter TargetName="track" Property="BorderBrush" Value="{StaticResource AccentHover}" />
                        </MultiTrigger>
                        <Trigger Property="IsKeyboardFocused" Value="True">
                            <Setter TargetName="track" Property="BorderBrush" Value="{StaticResource Accent}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="track" Property="BorderBrush" Value="{StaticResource DisabledText}" />
                            <Setter TargetName="knob" Property="Fill" Value="{StaticResource DisabledText}" />
                            <Setter Property="Cursor" Value="Arrow" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!--
        ============================================================
        Slider — thin track, accent thumb (flat, no shadow).
        ============================================================
    -->
    <Style x:Key="SliderThumb" TargetType="Thumb">
        <Setter Property="OverridesDefaultStyle" Value="True" />
        <Setter Property="Height" Value="20" />
        <Setter Property="Width" Value="20" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Thumb">
                    <Grid>
                        <Ellipse
                            x:Name="ring"
                            Fill="{StaticResource Card}"
                            Stroke="{StaticResource FieldStrongBorder}"
                            StrokeThickness="1" />
                        <Ellipse
                            x:Name="dot"
                            Width="11"
                            Height="11"
                            Fill="{StaticResource Accent}" />
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="dot" Property="Width" Value="13" />
                            <Setter TargetName="dot" Property="Height" Value="13" />
                        </Trigger>
                        <Trigger Property="IsDragging" Value="True">
                            <Setter TargetName="dot" Property="Width" Value="9" />
                            <Setter TargetName="dot" Property="Height" Value="9" />
                            <Setter TargetName="dot" Property="Fill" Value="{StaticResource AccentPressed}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="Slider">
        <Setter Property="Height" Value="22" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Slider">
                    <Grid VerticalAlignment="Center">
                        <Border
                            Height="4"
                            VerticalAlignment="Center"
                            Background="{StaticResource Track}"
                            CornerRadius="2" />
                        <Track x:Name="PART_Track">
                            <Track.DecreaseRepeatButton>
                                <RepeatButton Command="Slider.DecreaseLarge" Focusable="False">
                                    <RepeatButton.Template>
                                        <ControlTemplate TargetType="RepeatButton">
                                            <Border
                                                Height="4"
                                                VerticalAlignment="Center"
                                                Background="{StaticResource Accent}"
                                                CornerRadius="2" />
                                        </ControlTemplate>
                                    </RepeatButton.Template>
                                </RepeatButton>
                            </Track.DecreaseRepeatButton>
                            <Track.Thumb>
                                <Thumb Style="{StaticResource SliderThumb}" />
                            </Track.Thumb>
                            <Track.IncreaseRepeatButton>
                                <RepeatButton Command="Slider.IncreaseLarge" Focusable="False">
                                    <RepeatButton.Template>
                                        <ControlTemplate TargetType="RepeatButton">
                                            <Border Background="Transparent" />
                                        </ControlTemplate>
                                    </RepeatButton.Template>
                                </RepeatButton>
                            </Track.IncreaseRepeatButton>
                        </Track>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!--
        ============================================================
        Left-rail nav (TabControl) — masthead + Fluent NavigationView
        items (icon + label, accent selection bar).
        ============================================================
    -->
    <Style x:Key="NavTab" TargetType="TabItem">
        <Setter Property="Foreground" Value="{StaticResource TextSecondary}" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TabItem">
                    <Border
                        x:Name="bd"
                        Margin="6,1"
                        Background="Transparent"
                        CornerRadius="4">
                        <Grid>
                            <Border
                                x:Name="bar"
                                Width="3"
                                Height="16"
                                HorizontalAlignment="Left"
                                Background="{StaticResource Accent}"
                                CornerRadius="1.5"
                                Opacity="0" />
                            <StackPanel Margin="13,8" Orientation="Horizontal">
                                <TextBlock
                                    x:Name="icon"
                                    VerticalAlignment="Center"
                                    FontFamily="{StaticResource IconFont}"
                                    FontSize="20"
                                    Foreground="{StaticResource TextSecondary}"
                                    Text="{TemplateBinding Tag}" />
                                <ContentPresenter
                                    x:Name="label"
                                    Margin="12,0,0,0"
                                    VerticalAlignment="Center"
                                    ContentSource="Header" />
                            </StackPanel>
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bd" Property="Background" Value="{StaticResource ControlHover}" />
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="bd" Property="Background" Value="{StaticResource ControlHover}" />
                            <Setter TargetName="bar" Property="Opacity" Value="1" />
                            <Setter TargetName="icon" Property="Foreground" Value="{StaticResource Accent}" />
                            <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
                            <Setter Property="FontWeight" Value="SemiBold" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="NavTabControl" TargetType="TabControl">
        <Setter Property="ItemContainerStyle" Value="{StaticResource NavTab}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TabControl">
                    <Border
                        Background="{StaticResource Surface}"
                        BorderBrush="{StaticResource CardBorder}"
                        BorderThickness="1"
                        CornerRadius="8">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="186" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <!--  Masthead + nav rail  -->
                            <Border
                                Grid.Column="0"
                                Background="{StaticResource Rail}"
                                BorderBrush="{StaticResource CardBorder}"
                                BorderThickness="0,0,1,0"
                                CornerRadius="8,0,0,8">
                                <DockPanel LastChildFill="False">
                                    <StackPanel
                                        Margin="16,16,16,12"
                                        DockPanel.Dock="Top"
                                        Orientation="Horizontal">
                                        <Image
                                            Width="34"
                                            Height="34"
                                            VerticalAlignment="Center"
                                            Source="pack://application:,,,/ACT_DiscordTriggers;component/logo.png" />
                                        <StackPanel Margin="11,0,0,0" VerticalAlignment="Center">
                                            <TextBlock
                                                FontSize="14"
                                                FontWeight="SemiBold"
                                                Foreground="{StaticResource TextPrimary}"
                                                Text="Discord Triggers" />
                                            <TextBlock
                                                FontFamily="Segoe UI Variable Small, Segoe UI"
                                                FontSize="12"
                                                Foreground="{StaticResource TextMuted}"
                                                Text="Voice bridge for ACT" />
                                        </StackPanel>
                                    </StackPanel>
                                    <Border
                                        Height="1"
                                        Margin="14,0,14,8"
                                        Background="{StaticResource Divider}"
                                        DockPanel.Dock="Top" />
                                    <TabPanel
                                        Margin="0,2,0,0"
                                        DockPanel.Dock="Top"
                                        IsItemsHost="True" />
                                </DockPanel>
                            </Border>

                            <!--  Content  -->
                            <ContentPresenter Grid.Column="1" ContentSource="SelectedContent" />
                        </Grid>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!--
        ============================================================
        Diagnostics log — flat list with neutral headers.
        ============================================================
    -->
    <Style x:Key="LogColumnHeader" TargetType="GridViewColumnHeader">
        <Setter Property="FontFamily" Value="Segoe UI Variable Small, Segoe UI" />
        <Setter Property="Foreground" Value="{StaticResource TextSecondary}" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="HorizontalContentAlignment" Value="Left" />
        <Setter Property="Padding" Value="10,7" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="GridViewColumnHeader">
                    <Border
                        Background="#F3F7FC"
                        BorderBrush="{StaticResource Divider}"
                        BorderThickness="0,0,1,1">
                        <ContentPresenter
                            Margin="{TemplateBinding Padding}"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Center" />
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="LogItem" TargetType="ListViewItem">
        <Setter Property="Foreground" Value="{StaticResource TextSecondary}" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ListViewItem">
                    <Border
                        x:Name="bd"
                        Padding="0,1"
                        Background="Transparent">
                        <GridViewRowPresenter VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bd" Property="Background" Value="#F3F7FC" />
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="bd" Property="Background" Value="{StaticResource AccentSoft}" />
                            <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="LogList" TargetType="ListView">
        <Setter Property="FontFamily" Value="Cascadia Mono, Consolas, Courier New" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Background" Value="{StaticResource Card}" />
        <Setter Property="BorderBrush" Value="{StaticResource CardBorder}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="ItemContainerStyle" Value="{StaticResource LogItem}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ListView">
                    <Border
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="4">
                        <ScrollViewer Padding="1" Style="{x:Null}">
                            <ItemsPresenter />
                        </ScrollViewer>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!--  Fluent InfoBar — informational strip (used for the audio-quality notice).  -->
    <Style x:Key="InfoCallout" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource AccentSoft}" />
        <Setter Property="BorderBrush" Value="#BFD6F5" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="4" />
        <Setter Property="Padding" Value="12,10" />
        <!--  Bottom-only margin to match SettingsCard, so callouts keep the card rhythm above and below.  -->
        <Setter Property="Margin" Value="0,0,0,4" />
    </Style>

    <!--
        ============================================================
        EngineChoiceCard — a selectable card (RadioButton) for the
        Text-to-Speech engine pick. Two share a GroupName; the checked
        one takes the AccentSoft fill + accent border + a corner check.
        Inner content (icon + title + description) is passed as Content.
        ============================================================
    -->
    <Style x:Key="EngineChoiceCard" TargetType="RadioButton">
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="VerticalContentAlignment" Value="Top" />
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="RadioButton">
                    <Border
                        x:Name="bd"
                        MinHeight="74"
                        Padding="14,12"
                        Background="{StaticResource Card}"
                        BorderBrush="{StaticResource CardBorder}"
                        BorderThickness="1"
                        CornerRadius="4">
                        <Grid>
                            <ContentPresenter Margin="0,0,18,0" />
                            <TextBlock
                                x:Name="check"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Top"
                                FontFamily="{StaticResource IconFont}"
                                FontSize="16"
                                Foreground="{StaticResource Accent}"
                                Text="{StaticResource Icon.CheckCircle}"
                                Visibility="Collapsed" />
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bd" Property="BorderBrush" Value="{StaticResource FieldStrongBorder}" />
                        </Trigger>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="bd" Property="Background" Value="{StaticResource AccentSoft}" />
                            <Setter TargetName="bd" Property="BorderBrush" Value="{StaticResource Accent}" />
                            <Setter TargetName="check" Property="Visibility" Value="Visible" />
                        </Trigger>
                        <Trigger Property="IsKeyboardFocused" Value="True">
                            <Setter TargetName="bd" Property="BorderBrush" Value="{StaticResource Accent}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!--
        ============================================================
        SegmentButton — one segment of a Fluent segmented control
        (RadioButton). Host several in a bordered pill (FieldBg border,
        CornerRadius 6, Padding 2); the checked segment fills with accent.
        Used by the Quality (Piper|Kokoro) and CPU-usage toggles.
        ============================================================
    -->
    <Style x:Key="SegmentButton" TargetType="RadioButton">
        <Setter Property="Foreground" Value="{StaticResource TextSecondary}" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="RadioButton">
                    <Border
                        x:Name="bd"
                        Padding="14,5"
                        Background="Transparent"
                        CornerRadius="4">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bd" Property="Background" Value="{StaticResource ControlHover}" />
                        </Trigger>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="bd" Property="Background" Value="{StaticResource Accent}" />
                            <Setter Property="Foreground" Value="{StaticResource OnAccent}" />
                            <Setter Property="FontWeight" Value="SemiBold" />
                        </Trigger>
                        <Trigger Property="IsKeyboardFocused" Value="True">
                            <Setter TargetName="bd" Property="BorderBrush" Value="{StaticResource Accent}" />
                            <Setter TargetName="bd" Property="BorderThickness" Value="1" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="Segmented" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource FieldBg}" />
        <Setter Property="BorderBrush" Value="{StaticResource FieldBorder}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="6" />
        <Setter Property="Padding" Value="2" />
        <Setter Property="HorizontalAlignment" Value="Right" />
    </Style>

    <!--  A small round help glyph that opens a popover; always clickable, even when its sibling control is disabled.  -->
    <Style x:Key="HelpGlyphButton" TargetType="ToggleButton">
        <Setter Property="Width" Value="22" />
        <Setter Property="Height" Value="22" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ToggleButton">
                    <Border
                        x:Name="bd"
                        Background="Transparent"
                        CornerRadius="11">
                        <TextBlock
                            x:Name="glyph"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            FontFamily="{StaticResource IconFont}"
                            FontSize="16"
                            Foreground="{StaticResource TextMuted}"
                            Text="{StaticResource Icon.Help}" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="glyph" Property="Foreground" Value="{StaticResource Accent}" />
                        </Trigger>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="glyph" Property="Foreground" Value="{StaticResource Accent}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!--  Determinate download bar — Track rail + accent fill, matching the slider's flat language.  -->
    <Style x:Key="ThinProgress" TargetType="ProgressBar">
        <Setter Property="Height" Value="6" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ProgressBar">
                    <Grid>
                        <Border Background="{StaticResource Track}" CornerRadius="3" />
                        <Border x:Name="PART_Track" />
                        <Border
                            x:Name="PART_Indicator"
                            HorizontalAlignment="Left"
                            Background="{StaticResource Accent}"
                            CornerRadius="3" />
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!--
        ============================================================
        Voice picker — a ComboBox-shaped ToggleButton that opens a
        flyout with a search box over a grouped, filtered list. Used
        for the ONNX catalog (too many voices for a plain dropdown).
        ============================================================
    -->
    <Style x:Key="PickerButton" TargetType="ToggleButton">
        <Setter Property="Height" Value="32" />
        <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
        <Setter Property="HorizontalContentAlignment" Value="Left" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ToggleButton">
                    <Grid>
                        <Border
                            x:Name="bd"
                            Background="{StaticResource FieldBg}"
                            BorderBrush="{StaticResource FieldBorder}"
                            BorderThickness="1"
                            CornerRadius="4">
                            <Grid>
                                <ContentPresenter
                                    Margin="11,0,28,0"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Center" />
                                <TextBlock
                                    x:Name="arrow"
                                    Margin="0,0,12,0"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center"
                                    FontFamily="{StaticResource IconFont}"
                                    FontSize="16"
                                    Foreground="{StaticResource TextSecondary}"
                                    Text="{StaticResource Icon.ChevronDown}" />
                            </Grid>
                        </Border>
                        <Border
                            x:Name="underline"
                            Height="2"
                            VerticalAlignment="Bottom"
                            Background="{StaticResource Accent}"
                            CornerRadius="0,0,4,4"
                            Visibility="Collapsed" />
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bd" Property="BorderBrush" Value="{StaticResource FieldStrongBorder}" />
                        </Trigger>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="bd" Property="BorderBrush" Value="{StaticResource FieldStrongBorder}" />
                            <Setter TargetName="arrow" Property="Foreground" Value="{StaticResource Accent}" />
                            <Setter TargetName="underline" Property="Visibility" Value="Visible" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="PickerListItem" TargetType="ListBoxItem">
        <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
        <Setter Property="Padding" Value="10,7" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ListBoxItem">
                    <Border
                        x:Name="bd"
                        Padding="{TemplateBinding Padding}"
                        Background="Transparent"
                        CornerRadius="4">
                        <ContentPresenter />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bd" Property="Background" Value="{StaticResource ControlHover}" />
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="bd" Property="Background" Value="{StaticResource AccentSoft}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="PickerList" TargetType="ListBox">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled" />
        <Setter Property="ItemContainerStyle" Value="{StaticResource PickerListItem}" />
    </Style>

    <!--  Quiet disclosure toggle ("Advanced") — chevron + label, no card chrome; the chevron rotates open.  -->
    <Style x:Key="DisclosureToggle" TargetType="ToggleButton">
        <Setter Property="Foreground" Value="{StaticResource TextSecondary}" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="HorizontalAlignment" Value="Left" />
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ToggleButton">
                    <Border
                        x:Name="bd"
                        Padding="4,6"
                        Background="Transparent"
                        CornerRadius="4">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock
                                x:Name="chev"
                                VerticalAlignment="Center"
                                FontFamily="{StaticResource IconFont}"
                                FontSize="16"
                                Foreground="{StaticResource TextSecondary}"
                                RenderTransformOrigin="0.5,0.5"
                                Text="{StaticResource Icon.Chevron}">
                                <TextBlock.RenderTransform>
                                    <RotateTransform Angle="0" />
                                </TextBlock.RenderTransform>
                            </TextBlock>
                            <ContentPresenter Margin="8,0,0,0" VerticalAlignment="Center" />
                        </StackPanel>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bd" Property="Background" Value="{StaticResource ControlHover}" />
                            <Setter TargetName="chev" Property="Foreground" Value="{StaticResource TextPrimary}" />
                        </Trigger>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="chev" Property="RenderTransform">
                                <Setter.Value>
                                    <RotateTransform Angle="90" />
                                </Setter.Value>
                            </Setter>
                            <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
                            <Setter Property="FontWeight" Value="SemiBold" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
