<UserControl
    x:Class="ACT_DiscordTriggers.DiscordTriggersView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
    xmlns:local="clr-namespace:ACT_DiscordTriggers"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="730"
    d:DesignWidth="760"
    Background="#EFF4FA"
    FontFamily="Segoe UI"
    FontSize="13"
    Foreground="#1C2A3A"
    mc:Ignorable="d">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/ACT_DiscordTriggers;component/Theme.xaml" />
            </ResourceDictionary.MergedDictionaries>
            <BooleanToVisibilityConverter x:Key="BoolToVis" />

            <!--
                Connection status indicator: a soft halo behind a solid dot, plus a label.
                All three flip on the VM's IsConnected (red/"Disconnected" -> green/"Connected").
            -->
            <Style x:Key="StatusHalo" TargetType="Ellipse">
                <Setter Property="Width" Value="16" />
                <Setter Property="Height" Value="16" />
                <Setter Property="Opacity" Value="0.20" />
                <Setter Property="Fill" Value="{StaticResource StatusOffline}" />
                <Style.Triggers>
                    <DataTrigger Binding="{Binding IsConnected}" Value="True">
                        <Setter Property="Fill" Value="{StaticResource StatusOnline}" />
                    </DataTrigger>
                </Style.Triggers>
            </Style>
            <Style x:Key="StatusDot" TargetType="Ellipse">
                <Setter Property="Width" Value="9" />
                <Setter Property="Height" Value="9" />
                <Setter Property="HorizontalAlignment" Value="Center" />
                <Setter Property="VerticalAlignment" Value="Center" />
                <Setter Property="Fill" Value="{StaticResource StatusOffline}" />
                <Style.Triggers>
                    <DataTrigger Binding="{Binding IsConnected}" Value="True">
                        <Setter Property="Fill" Value="{StaticResource StatusOnline}" />
                    </DataTrigger>
                </Style.Triggers>
            </Style>
            <Style x:Key="StatusText" TargetType="TextBlock">
                <Setter Property="VerticalAlignment" Value="Center" />
                <Setter Property="Margin" Value="9,0,0,0" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="Foreground" Value="{StaticResource TextMuted}" />
                <Setter Property="Text" Value="Disconnected" />
                <Style.Triggers>
                    <DataTrigger Binding="{Binding IsConnected}" Value="True">
                        <Setter Property="Foreground" Value="{StaticResource TextSecondary}" />
                        <Setter Property="Text" Value="Connected" />
                    </DataTrigger>
                </Style.Triggers>
            </Style>
        </ResourceDictionary>
    </UserControl.Resources>

    <DockPanel Margin="14" LastChildFill="True">

        <!--  Diagnostics log: docked at the bottom across the full width.  -->
        <DockPanel
            Height="206"
            Margin="0,14,0,0"
            DockPanel.Dock="Bottom">
            <TextBlock
                DockPanel.Dock="Top"
                Style="{StaticResource Eyebrow}"
                Text="DIAGNOSTICS" />
            <ListView
                local:LogListCopy.Enabled="True"
                ItemsSource="{Binding LogEntries}"
                SelectionMode="Extended"
                Style="{StaticResource LogList}">
                <ListView.View>
                    <GridView ColumnHeaderContainerStyle="{StaticResource LogColumnHeader}">
                        <GridViewColumn
                            Width="170"
                            DisplayMemberBinding="{Binding Timestamp, StringFormat='{}{0:G}'}"
                            Header="Timestamp" />
                        <GridViewColumn
                            Width="560"
                            DisplayMemberBinding="{Binding Message}"
                            Header="Message" />
                    </GridView>
                </ListView.View>
            </ListView>
        </DockPanel>

        <!--  Left-rail navigation (General / Sound / Information) over the remaining area.  -->
        <TabControl Style="{StaticResource NavTabControl}" TabStripPlacement="Left">

            <!--  ===== General =====  -->
            <TabItem Header="General">
                <ScrollViewer Padding="24,22" VerticalScrollBarVisibility="Auto">
                    <StackPanel MaxWidth="560" HorizontalAlignment="Left">
                        <GroupBox Header="DISCORD CONNECTION">
                            <StackPanel>
                                <TextBlock Style="{StaticResource FieldLabel}" Text="Discord bot token" />
                                <PasswordBox
                                    MaxWidth="360"
                                    Margin="0,0,0,14"
                                    HorizontalAlignment="Left"
                                    local:PasswordBoxBinding.BoundPassword="{Binding BotToken, UpdateSourceTrigger=PropertyChanged}" />
                                <StackPanel Margin="0,0,0,14" Orientation="Horizontal">
                                    <!--  Connect / Disconnect occupy the same slot; IsConnected toggles which is shown.  -->
                                    <Button
                                        MinWidth="132"
                                        Command="{Binding ConnectCommand}"
                                        Content="Connect">
                                        <Button.Style>
                                            <Style BasedOn="{StaticResource PrimaryButton}" TargetType="Button">
                                                <Setter Property="Visibility" Value="Visible" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsConnected}" Value="True">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                    <Button
                                        MinWidth="132"
                                        Command="{Binding DisconnectCommand}"
                                        Content="Disconnect">
                                        <Button.Style>
                                            <Style BasedOn="{StaticResource PrimaryButton}" TargetType="Button">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsConnected}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                    <!--  Live connection status: glowing dot + label, driven by IsConnected.  -->
                                    <StackPanel
                                        Margin="20,0,0,0"
                                        VerticalAlignment="Center"
                                        Orientation="Horizontal">
                                        <Grid
                                            Width="16"
                                            Height="16"
                                            VerticalAlignment="Center">
                                            <Ellipse Style="{StaticResource StatusHalo}" />
                                            <Ellipse Style="{StaticResource StatusDot}" />
                                        </Grid>
                                        <TextBlock Style="{StaticResource StatusText}" />
                                    </StackPanel>
                                    <CheckBox
                                        Margin="18,0,0,0"
                                        VerticalAlignment="Center"
                                        Content="Connect automatically"
                                        IsChecked="{Binding AutoConnect}" />
                                </StackPanel>
                                <TextBlock Style="{StaticResource FieldLabel}" Text="Bot status message" />
                                <TextBox
                                    MaxWidth="360"
                                    HorizontalAlignment="Left"
                                    Text="{Binding BotStatus, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                        </GroupBox>

                        <GroupBox Margin="0,0,0,0" Header="VOICE CHANNEL">
                            <StackPanel>
                                <TextBlock Style="{StaticResource FieldLabel}" Text="Server" />
                                <ComboBox
                                    MaxWidth="360"
                                    Margin="0,0,0,14"
                                    HorizontalAlignment="Left"
                                    ItemsSource="{Binding Servers}"
                                    SelectedItem="{Binding SelectedServer}" />
                                <TextBlock Style="{StaticResource FieldLabel}" Text="Channel" />
                                <ComboBox
                                    MaxWidth="360"
                                    Margin="0,0,0,16"
                                    HorizontalAlignment="Left"
                                    ItemsSource="{Binding Channels}"
                                    SelectedItem="{Binding SelectedChannel}" />
                                <StackPanel Orientation="Horizontal">
                                    <Button
                                        MinWidth="132"
                                        Command="{Binding JoinCommand}"
                                        Content="Join channel"
                                        Style="{StaticResource PrimaryButton}" />
                                    <Button
                                        MinWidth="132"
                                        Margin="12,0,0,0"
                                        Command="{Binding LeaveCommand}"
                                        Content="Leave channel" />
                                </StackPanel>
                            </StackPanel>
                        </GroupBox>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!--  ===== Sound =====  -->
            <TabItem Header="Sound">
                <ScrollViewer Padding="24,22" VerticalScrollBarVisibility="Auto">
                    <StackPanel MaxWidth="560" HorizontalAlignment="Left">
                        <GroupBox Header="TEXT-TO-SPEECH">
                            <StackPanel>
                                <TextBlock Style="{StaticResource FieldLabel}" Text="Voice" />
                                <ComboBox
                                    MaxWidth="360"
                                    Margin="0,0,0,16"
                                    HorizontalAlignment="Left"
                                    ItemsSource="{Binding Voices}"
                                    SelectedItem="{Binding TtsVoice}" />
                                <TextBlock Style="{StaticResource FieldLabel}" Text="Volume" />
                                <Slider
                                    Width="340"
                                    Margin="0,0,0,16"
                                    HorizontalAlignment="Left"
                                    Maximum="20"
                                    Minimum="0"
                                    Value="{Binding TtsVolume}" />
                                <TextBlock Style="{StaticResource FieldLabel}" Text="Speed" />
                                <Slider
                                    Width="340"
                                    HorizontalAlignment="Left"
                                    Maximum="20"
                                    Minimum="0"
                                    Value="{Binding TtsSpeed}" />
                            </StackPanel>
                        </GroupBox>

                        <GroupBox Margin="0,0,0,0" Header="EFFECTS &amp; LEVELING">
                            <StackPanel>
                                <CheckBox
                                    Margin="0,0,0,10"
                                    Content="Random sound effects"
                                    IsChecked="{Binding RandomFx}" />
                                <TextBlock Style="{StaticResource FieldLabel}" Text="{Binding FxChanceLabel}" />
                                <Slider
                                    Width="340"
                                    Margin="0,0,0,18"
                                    HorizontalAlignment="Left"
                                    Maximum="100"
                                    Minimum="0"
                                    Value="{Binding FxChance}" />
                                <CheckBox
                                    Margin="0,0,0,10"
                                    Content="Auto-level volume"
                                    IsChecked="{Binding Normalize}" />
                                <TextBlock Style="{StaticResource FieldLabel}" Text="{Binding NormalizeTargetLabel}" />
                                <Slider
                                    Width="340"
                                    Margin="0,0,0,16"
                                    HorizontalAlignment="Left"
                                    Maximum="30"
                                    Minimum="12"
                                    Value="{Binding NormalizeTarget}" />
                                <TextBlock Style="{StaticResource FieldLabel}" Text="Audio quality" />
                                <ComboBox
                                    Width="220"
                                    HorizontalAlignment="Left"
                                    SelectedIndex="{Binding AudioQualityIndex}">
                                    <ComboBoxItem>Low (48 kbps)</ComboBoxItem>
                                    <ComboBoxItem>Medium (96 kbps)</ComboBoxItem>
                                    <ComboBoxItem>High (128 kbps)</ComboBoxItem>
                                </ComboBox>
                                <Border Style="{StaticResource InfoCallout}" Visibility="{Binding ShowHighQualityWarning, Converter={StaticResource BoolToVis}}">
                                    <TextBlock
                                        Foreground="{StaticResource TextPrimary}"
                                        Text="High quality needs a Discord channel that supports 128 kbps (a boosted server)."
                                        TextWrapping="Wrap" />
                                </Border>
                            </StackPanel>
                        </GroupBox>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!--  ===== Information =====  -->
            <TabItem Header="Information">
                <ScrollViewer Padding="24,22" VerticalScrollBarVisibility="Auto">
                    <StackPanel MaxWidth="520" HorizontalAlignment="Center">
                        <Image
                            Width="112"
                            Height="112"
                            Margin="0,8,0,10"
                            HorizontalAlignment="Center"
                            Source="pack://application:,,,/ACT_DiscordTriggers;component/logo.png" />
                        <TextBlock
                            HorizontalAlignment="Center"
                            FontSize="21"
                            FontWeight="Bold"
                            Foreground="{StaticResource TextPrimary}"
                            Text="ACT Discord Triggers" />
                        <TextBlock
                            Margin="0,2,0,10"
                            HorizontalAlignment="Center"
                            Foreground="{StaticResource TextMuted}"
                            Text="{x:Static local:DiscordTriggersPlugin.VersionDisplay}" />
                        <TextBlock
                            Margin="0,0,0,4"
                            Foreground="{StaticResource TextSecondary}"
                            Text="Play your ACT triggers — text-to-speech and sound effects — through a Discord voice bot, so your whole party hears them."
                            TextAlignment="Center"
                            TextWrapping="Wrap" />

                        <Border
                            Height="1"
                            Margin="40,18"
                            Background="{StaticResource Divider}" />

                        <StackPanel Margin="0,0,0,4" HorizontalAlignment="Center">
                            <TextBlock Margin="0,3" Foreground="{StaticResource Accent}">
                                <Hyperlink Foreground="{StaticResource Accent}" NavigateUri="https://github.com/jlagedo/ACT-Discord-Triggers">
                                    <i:Interaction.Triggers>
                                        <i:EventTrigger EventName="RequestNavigate">
                                            <i:LaunchUriOrFileAction Path="https://github.com/jlagedo/ACT-Discord-Triggers" />
                                        </i:EventTrigger>
                                    </i:Interaction.Triggers>
                                    ↗  Project on GitHub
                                </Hyperlink>
                            </TextBlock>
                            <TextBlock Margin="0,3" Foreground="{StaticResource Accent}">
                                <Hyperlink Foreground="{StaticResource Accent}" NavigateUri="https://github.com/jlagedo/ACT-Discord-Triggers/issues/new">
                                    <i:Interaction.Triggers>
                                        <i:EventTrigger EventName="RequestNavigate">
                                            <i:LaunchUriOrFileAction Path="https://github.com/jlagedo/ACT-Discord-Triggers/issues/new" />
                                        </i:EventTrigger>
                                    </i:Interaction.Triggers>
                                    ↗  Report a problem / open an issue
                                </Hyperlink>
                            </TextBlock>
                            <TextBlock Margin="0,3" Foreground="{StaticResource Accent}">
                                <Hyperlink Foreground="{StaticResource Accent}" NavigateUri="https://github.com/jlagedo/ACT-Discord-Triggers/wiki/First-Time-Setup-Guide">
                                    <i:Interaction.Triggers>
                                        <i:EventTrigger EventName="RequestNavigate">
                                            <i:LaunchUriOrFileAction Path="https://github.com/jlagedo/ACT-Discord-Triggers/wiki/First-Time-Setup-Guide" />
                                        </i:EventTrigger>
                                    </i:Interaction.Triggers>
                                    ↗  First-Time Setup Guide
                                </Hyperlink>
                            </TextBlock>
                        </StackPanel>

                        <Border
                            Height="1"
                            Margin="40,18"
                            Background="{StaticResource Divider}" />

                        <TextBlock
                            Margin="0,0,0,10"
                            Foreground="{StaticResource TextSecondary}"
                            Text="Hit a bug? Open the diagnostics log and attach it to your report."
                            TextAlignment="Center"
                            TextWrapping="Wrap" />
                        <Button
                            Margin="0,0,0,4"
                            HorizontalAlignment="Center"
                            Command="{Binding OpenLogFolderCommand}"
                            Content="Open log folder" />

                        <Border
                            Height="1"
                            Margin="40,18"
                            Background="{StaticResource Divider}" />

                        <TextBlock
                            Margin="0,2,0,0"
                            FontSize="11"
                            Foreground="{StaticResource TextMuted}"
                            Text="ACT Discord Triggers is a community plugin — not affiliated with or endorsed by Discord, Square Enix, or Advanced Combat Tracker. Provided as-is under the MIT License, without warranty; use at your own risk and follow Discord's Terms of Service. Originally created by Makar8000."
                            TextAlignment="Center"
                            TextWrapping="Wrap" />
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

        </TabControl>
    </DockPanel>
</UserControl>
