<UserControl
    x:Class="ACT_DiscordTriggers.DiscordTriggersView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
    xmlns:local="clr-namespace:ACT_DiscordTriggers"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="730"
    d:DesignWidth="760"
    Background="#EFF4FA"
    FontFamily="Segoe UI Variable Text, Segoe UI"
    FontSize="14"
    Foreground="#1C2A3A"
    mc:Ignorable="d">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/ACT_DiscordTriggers;component/Theme.xaml" />
            </ResourceDictionary.MergedDictionaries>
            <BooleanToVisibilityConverter x:Key="BoolToVis" />

            <!--  ONNX catalog grouped by locale + live-filtered by the picker's search box (OnnxVoiceFilter).  -->
            <CollectionViewSource
                x:Key="OnnxVoicesView"
                Filter="OnnxVoiceFilter"
                Source="{Binding OnnxVoices}">
                <CollectionViewSource.GroupDescriptions>
                    <PropertyGroupDescription PropertyName="LocaleName" />
                </CollectionViewSource.GroupDescriptions>
            </CollectionViewSource>

            <!--
                ONNX voice row: ★ recommended, the voice name with a muted tier
                suffix, and install-state on the right — ✓ when on disk, the
                download size when not. Locale is carried by the group header.
            -->
            <DataTemplate x:Key="OnnxVoiceItemTemplate">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock
                            x:Name="star"
                            Margin="0,0,6,0"
                            VerticalAlignment="Center"
                            FontFamily="{StaticResource IconFont}"
                            FontSize="16"
                            Foreground="{StaticResource Accent}"
                            Text="{StaticResource Icon.Star}"
                            Visibility="Collapsed" />
                        <TextBlock VerticalAlignment="Center" Text="{Binding Name}" />
                        <TextBlock
                            Margin="6,0,0,0"
                            VerticalAlignment="Center"
                            Foreground="{StaticResource TextMuted}"
                            Text="{Binding TierLabel}" />
                    </StackPanel>
                    <Grid Grid.Column="1" Margin="12,0,0,0">
                        <TextBlock
                            x:Name="check"
                            FontFamily="{StaticResource IconFont}"
                            FontSize="16"
                            Foreground="{StaticResource Accent}"
                            Text="{StaticResource Icon.CheckCircle}"
                            Visibility="Collapsed" />
                        <TextBlock
                            x:Name="size"
                            VerticalAlignment="Center"
                            FontSize="12"
                            Foreground="{StaticResource TextMuted}"
                            Text="{Binding SizeText}" />
                    </Grid>
                </Grid>
                <DataTemplate.Triggers>
                    <DataTrigger Binding="{Binding Recommended}" Value="True">
                        <Setter TargetName="star" Property="Visibility" Value="Visible" />
                    </DataTrigger>
                    <DataTrigger Binding="{Binding Installed}" Value="True">
                        <Setter TargetName="check" Property="Visibility" Value="Visible" />
                        <Setter TargetName="size" Property="Visibility" Value="Collapsed" />
                    </DataTrigger>
                </DataTemplate.Triggers>
            </DataTemplate>

            <!--
                Connection status indicator: a soft halo behind a solid dot, plus a label.
                All three flip on the VM's IsConnected (red/"Disconnected" -> green/"Connected").
            -->
            <Style x:Key="StatusHalo" TargetType="Ellipse">
                <Setter Property="Width" Value="14" />
                <Setter Property="Height" Value="14" />
                <Setter Property="Opacity" Value="0.20" />
                <Setter Property="Fill" Value="{StaticResource StatusOffline}" />
                <Style.Triggers>
                    <DataTrigger Binding="{Binding IsConnected}" Value="True">
                        <Setter Property="Fill" Value="{StaticResource StatusOnline}" />
                    </DataTrigger>
                </Style.Triggers>
            </Style>
            <Style x:Key="StatusDot" TargetType="Ellipse">
                <Setter Property="Width" Value="8" />
                <Setter Property="Height" Value="8" />
                <Setter Property="HorizontalAlignment" Value="Center" />
                <Setter Property="VerticalAlignment" Value="Center" />
                <Setter Property="Fill" Value="{StaticResource StatusOffline}" />
                <Style.Triggers>
                    <DataTrigger Binding="{Binding IsConnected}" Value="True">
                        <Setter Property="Fill" Value="{StaticResource StatusOnline}" />
                    </DataTrigger>
                </Style.Triggers>
            </Style>
            <Style x:Key="StatusText" TargetType="TextBlock">
                <Setter Property="VerticalAlignment" Value="Center" />
                <Setter Property="Margin" Value="7,0,0,0" />
                <Setter Property="FontSize" Value="12" />
                <Setter Property="Foreground" Value="{StaticResource TextSecondary}" />
                <Setter Property="Text" Value="Disconnected" />
                <Style.Triggers>
                    <DataTrigger Binding="{Binding IsConnected}" Value="True">
                        <Setter Property="Text" Value="Connected" />
                    </DataTrigger>
                </Style.Triggers>
            </Style>
        </ResourceDictionary>
    </UserControl.Resources>

    <DockPanel LastChildFill="True">

        <!--  Diagnostics log: docked at the bottom across the full width.  -->
        <DockPanel
            Height="200"
            Margin="0,12,0,0"
            DockPanel.Dock="Bottom">
            <TextBlock
                Margin="2,0,0,8"
                DockPanel.Dock="Top"
                Style="{StaticResource SectionHeader}"
                Text="Diagnostics" />
            <ListView
                local:LogAutoScroll.Enabled="True"
                local:LogListCopy.Enabled="True"
                ItemsSource="{Binding LogEntries}"
                SelectionMode="Extended"
                Style="{StaticResource LogList}">
                <ListView.View>
                    <GridView ColumnHeaderContainerStyle="{StaticResource LogColumnHeader}">
                        <GridViewColumn
                            Width="170"
                            DisplayMemberBinding="{Binding Timestamp, StringFormat='{}{0:G}'}"
                            Header="Timestamp" />
                        <GridViewColumn
                            Width="560"
                            DisplayMemberBinding="{Binding Message}"
                            Header="Message" />
                    </GridView>
                </ListView.View>
            </ListView>
        </DockPanel>

        <!--  Left-rail navigation (General / Sound / Information) over the remaining area.  -->
        <TabControl Style="{StaticResource NavTabControl}" TabStripPlacement="Left">

            <!--  ===== General =====  -->
            <TabItem Header="General" Tag="{StaticResource Icon.General}">
                <ScrollViewer Padding="20,16" VerticalScrollBarVisibility="Auto">
                    <StackPanel MaxWidth="640">

                        <TextBlock
                            Margin="2,0,0,8"
                            Style="{StaticResource SectionHeader}"
                            Text="Discord connection" />

                        <HeaderedContentControl Style="{StaticResource SettingsCard}" Tag="{StaticResource Icon.Key}">
                            <HeaderedContentControl.Header>
                                <StackPanel>
                                    <TextBlock Style="{StaticResource CardTitle}" Text="Bot token" />
                                    <TextBlock Style="{StaticResource CardDesc}" Text="Used to sign in to your Discord bot." />
                                </StackPanel>
                            </HeaderedContentControl.Header>
                            <PasswordBox Width="220" local:PasswordBoxBinding.BoundPassword="{Binding BotToken, UpdateSourceTrigger=PropertyChanged}" />
                        </HeaderedContentControl>

                        <HeaderedContentControl Style="{StaticResource SettingsCard}" Tag="{StaticResource Icon.PlugConnected}">
                            <HeaderedContentControl.Header>
                                <StackPanel>
                                    <TextBlock Style="{StaticResource CardTitle}" Text="Connection" />
                                    <StackPanel Margin="0,3,0,0" Orientation="Horizontal">
                                        <Grid
                                            Width="14"
                                            Height="14"
                                            VerticalAlignment="Center">
                                            <Ellipse Style="{StaticResource StatusHalo}" />
                                            <Ellipse Style="{StaticResource StatusDot}" />
                                        </Grid>
                                        <TextBlock Style="{StaticResource StatusText}" />
                                    </StackPanel>
                                </StackPanel>
                            </HeaderedContentControl.Header>
                            <!--  Connect / Disconnect share the slot; IsConnected toggles which is shown.  -->
                            <Grid>
                                <Button
                                    MinWidth="120"
                                    Command="{Binding ConnectCommand}"
                                    Content="Connect">
                                    <Button.Style>
                                        <Style BasedOn="{StaticResource PrimaryButton}" TargetType="Button">
                                            <Setter Property="Visibility" Value="Visible" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsConnected}" Value="True">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                                <Button
                                    MinWidth="120"
                                    Command="{Binding DisconnectCommand}"
                                    Content="Disconnect">
                                    <Button.Style>
                                        <Style BasedOn="{StaticResource {x:Type Button}}" TargetType="Button">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsConnected}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                            </Grid>
                        </HeaderedContentControl>

                        <HeaderedContentControl Style="{StaticResource SettingsCard}" Tag="{StaticResource Icon.AutoConnect}">
                            <HeaderedContentControl.Header>
                                <StackPanel>
                                    <TextBlock Style="{StaticResource CardTitle}" Text="Connect automatically" />
                                    <TextBlock Style="{StaticResource CardDesc}" Text="Reconnect when ACT starts." />
                                </StackPanel>
                            </HeaderedContentControl.Header>
                            <CheckBox IsChecked="{Binding AutoConnect}" Style="{StaticResource ToggleSwitch}" />
                        </HeaderedContentControl>

                        <HeaderedContentControl Style="{StaticResource SettingsCard}" Tag="{StaticResource Icon.Chat}">
                            <HeaderedContentControl.Header>
                                <StackPanel>
                                    <TextBlock Style="{StaticResource CardTitle}" Text="Bot status message" />
                                    <TextBlock Style="{StaticResource CardDesc}" Text="Shown on the bot's Discord profile." />
                                </StackPanel>
                            </HeaderedContentControl.Header>
                            <TextBox Width="220" Text="{Binding BotStatus, UpdateSourceTrigger=PropertyChanged}" />
                        </HeaderedContentControl>

                        <TextBlock Style="{StaticResource SectionHeader}" Text="Voice channel" />

                        <HeaderedContentControl
                            Header="Server"
                            Style="{StaticResource SettingsCard}"
                            Tag="{StaticResource Icon.Server}">
                            <ComboBox
                                Width="220"
                                ItemsSource="{Binding Servers}"
                                SelectedItem="{Binding SelectedServer}" />
                        </HeaderedContentControl>

                        <HeaderedContentControl
                            Header="Channel"
                            Style="{StaticResource SettingsCard}"
                            Tag="{StaticResource Icon.Channel}">
                            <ComboBox
                                Width="220"
                                ItemsSource="{Binding Channels}"
                                SelectedItem="{Binding SelectedChannel}" />
                        </HeaderedContentControl>

                        <HeaderedContentControl Style="{StaticResource SettingsCard}" Tag="{StaticResource Icon.Voice}">
                            <HeaderedContentControl.Header>
                                <StackPanel>
                                    <TextBlock Style="{StaticResource CardTitle}" Text="Voice connection" />
                                    <TextBlock Style="{StaticResource CardDesc}" Text="Join or leave the selected channel." />
                                </StackPanel>
                            </HeaderedContentControl.Header>
                            <StackPanel Orientation="Horizontal">
                                <Button
                                    MinWidth="120"
                                    Command="{Binding JoinCommand}"
                                    Content="Join channel"
                                    Style="{StaticResource PrimaryButton}" />
                                <Button
                                    MinWidth="120"
                                    Margin="8,0,0,0"
                                    Command="{Binding LeaveCommand}"
                                    Content="Leave" />
                            </StackPanel>
                        </HeaderedContentControl>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!--  ===== Text-to-Speech =====  -->
            <TabItem Header="Text-to-Speech" Tag="{StaticResource Icon.Voice}">
                <ScrollViewer
                    x:Name="TtsScroller"
                    Padding="20,16"
                    VerticalScrollBarVisibility="Auto">
                    <StackPanel MaxWidth="640">

                        <!--  Engine — the page's organizing choice; selecting one reshapes the body below.  -->
                        <TextBlock
                            Margin="2,0,0,8"
                            Style="{StaticResource SectionHeader}"
                            Text="Engine" />

                        <UniformGrid Columns="2">
                            <RadioButton
                                Margin="0,0,5,0"
                                GroupName="engine"
                                IsChecked="{Binding IsSapi, Mode=TwoWay}"
                                Style="{StaticResource EngineChoiceCard}">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock
                                            VerticalAlignment="Center"
                                            FontFamily="{StaticResource IconFont}"
                                            FontSize="20"
                                            Foreground="{StaticResource TextSecondary}"
                                            Text="{StaticResource Icon.Desktop}" />
                                        <TextBlock
                                            Margin="9,0,0,0"
                                            VerticalAlignment="Center"
                                            FontWeight="SemiBold"
                                            Foreground="{StaticResource TextPrimary}"
                                            Text="Windows (SAPI)" />
                                    </StackPanel>
                                    <TextBlock
                                        Margin="0,6,0,0"
                                        Style="{StaticResource CardDesc}"
                                        Text="Built-in system voices. Offline, nothing to download." />
                                </StackPanel>
                            </RadioButton>
                            <RadioButton
                                Margin="5,0,0,0"
                                GroupName="engine"
                                IsChecked="{Binding IsOnnx, Mode=TwoWay}"
                                Style="{StaticResource EngineChoiceCard}">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock
                                            VerticalAlignment="Center"
                                            FontFamily="{StaticResource IconFont}"
                                            FontSize="20"
                                            Foreground="{StaticResource Accent}"
                                            Text="{StaticResource Icon.Sparkle}" />
                                        <TextBlock
                                            Margin="9,0,0,0"
                                            VerticalAlignment="Center"
                                            FontWeight="SemiBold"
                                            Foreground="{StaticResource TextPrimary}"
                                            Text="ONNX — neural" />
                                    </StackPanel>
                                    <TextBlock
                                        Margin="0,6,0,0"
                                        Style="{StaticResource CardDesc}"
                                        Text="Natural voices, downloaded as you pick them." />
                                </StackPanel>
                            </RadioButton>
                        </UniformGrid>

                        <TextBlock Style="{StaticResource SectionHeader}" Text="Voice" />

                        <!--  SAPI body — today's controls, unchanged.  -->
                        <StackPanel Visibility="{Binding IsSapi, Converter={StaticResource BoolToVis}}">
                            <HeaderedContentControl
                                Header="Voice"
                                Style="{StaticResource SettingsCard}"
                                Tag="{StaticResource Icon.Voice}">
                                <ComboBox
                                    Width="220"
                                    ItemsSource="{Binding Voices}"
                                    SelectedItem="{Binding TtsVoice}" />
                            </HeaderedContentControl>

                            <HeaderedContentControl
                                Header="{Binding TtsVolume, StringFormat='Volume: {0}'}"
                                Style="{StaticResource SettingsCard}"
                                Tag="{StaticResource Icon.Sound}">
                                <Slider
                                    Width="200"
                                    Maximum="20"
                                    Minimum="0"
                                    Value="{Binding TtsVolume}" />
                            </HeaderedContentControl>

                            <HeaderedContentControl
                                Header="{Binding TtsSpeed, StringFormat='Speed: {0}'}"
                                Style="{StaticResource SettingsCard}"
                                Tag="{StaticResource Icon.Speed}">
                                <Slider
                                    Width="200"
                                    Maximum="20"
                                    Minimum="0"
                                    Value="{Binding TtsSpeed}" />
                            </HeaderedContentControl>
                        </StackPanel>

                        <!--  ONNX body — quality toggle, catalog dropdown, inline download, speed.  -->
                        <StackPanel Visibility="{Binding IsOnnx, Converter={StaticResource BoolToVis}}">
                            <HeaderedContentControl Style="{StaticResource SettingsCard}" Tag="{StaticResource Icon.Sparkle}">
                                <HeaderedContentControl.Header>
                                    <StackPanel>
                                        <TextBlock Style="{StaticResource CardTitle}" Text="Quality" />
                                        <TextBlock Style="{StaticResource CardDesc}" Text="{Binding QualityDescription}" />
                                    </StackPanel>
                                </HeaderedContentControl.Header>
                                <Border Style="{StaticResource Segmented}">
                                    <StackPanel Orientation="Horizontal">
                                        <RadioButton
                                            Content="Fast"
                                            GroupName="quality"
                                            IsChecked="{Binding IsPiper, Mode=TwoWay}"
                                            Style="{StaticResource SegmentButton}" />
                                        <RadioButton
                                            Content="Natural"
                                            GroupName="quality"
                                            IsChecked="{Binding IsKokoro, Mode=TwoWay}"
                                            Style="{StaticResource SegmentButton}" />
                                    </StackPanel>
                                </Border>
                            </HeaderedContentControl>

                            <HeaderedContentControl
                                Header="Voice"
                                Style="{StaticResource SettingsCard}"
                                Tag="{StaticResource Icon.Voice}">
                                <Grid Width="280">
                                    <ToggleButton
                                        x:Name="VoicePickerButton"
                                        Checked="OnVoicePickerOpened"
                                        Style="{StaticResource PickerButton}">
                                        <TextBlock Text="{Binding SelectedOnnxVoice.Label, FallbackValue='Select a voice', TargetNullValue='Select a voice'}" />
                                    </ToggleButton>
                                    <Popup
                                        AllowsTransparency="True"
                                        Focusable="False"
                                        IsOpen="{Binding IsChecked, ElementName=VoicePickerButton}"
                                        Placement="Bottom"
                                        PlacementTarget="{Binding ElementName=VoicePickerButton}"
                                        PopupAnimation="Fade"
                                        StaysOpen="False">
                                        <Border
                                            MinWidth="{Binding ActualWidth, ElementName=VoicePickerButton}"
                                            MaxHeight="380"
                                            Margin="0,4,0,6"
                                            Background="{StaticResource Card}"
                                            BorderBrush="{StaticResource CardBorder}"
                                            BorderThickness="1"
                                            CornerRadius="8"
                                            Effect="{StaticResource FlyoutShadow}">
                                            <DockPanel Margin="6">
                                                <Grid Margin="0,0,0,6" DockPanel.Dock="Top">
                                                    <TextBox x:Name="VoiceSearchBox" TextChanged="OnVoiceSearchChanged" />
                                                    <TextBlock
                                                        Margin="15,0,0,0"
                                                        VerticalAlignment="Center"
                                                        Foreground="{StaticResource TextMuted}"
                                                        IsHitTestVisible="False"
                                                        Text="Search voices…">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding Text, ElementName=VoiceSearchBox}" Value="">
                                                                        <Setter Property="Visibility" Value="Visible" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </Grid>
                                                <ListBox
                                                    x:Name="VoiceList"
                                                    ItemTemplate="{StaticResource OnnxVoiceItemTemplate}"
                                                    ItemsSource="{Binding Source={StaticResource OnnxVoicesView}}"
                                                    SelectionChanged="OnVoiceListSelectionChanged"
                                                    Style="{StaticResource PickerList}">
                                                    <ListBox.GroupStyle>
                                                        <GroupStyle>
                                                            <GroupStyle.HeaderTemplate>
                                                                <DataTemplate>
                                                                    <TextBlock
                                                                        Margin="6,8,0,2"
                                                                        FontFamily="Segoe UI Variable Small, Segoe UI"
                                                                        FontSize="12"
                                                                        FontWeight="SemiBold"
                                                                        Foreground="{StaticResource TextMuted}"
                                                                        Text="{Binding Name}" />
                                                                </DataTemplate>
                                                            </GroupStyle.HeaderTemplate>
                                                        </GroupStyle>
                                                    </ListBox.GroupStyle>
                                                </ListBox>
                                            </DockPanel>
                                        </Border>
                                    </Popup>
                                </Grid>
                            </HeaderedContentControl>

                            <Border Style="{StaticResource InfoCallout}" Visibility="{Binding ShowDownloadStrip, Converter={StaticResource BoolToVis}}">
                                <Grid>
                                    <!--  Idle: needs-download notice + button.  -->
                                    <Grid Visibility="{Binding DownloadButtonVisible, Converter={StaticResource BoolToVis}}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock
                                            Grid.Column="0"
                                            Margin="0,0,10,0"
                                            VerticalAlignment="Center"
                                            FontFamily="{StaticResource IconFont}"
                                            FontSize="16"
                                            Foreground="{StaticResource Accent}"
                                            Text="{StaticResource Icon.Download}" />
                                        <TextBlock
                                            Grid.Column="1"
                                            VerticalAlignment="Center"
                                            Foreground="{StaticResource TextPrimary}"
                                            Text="{Binding DownloadNoticeText}"
                                            TextWrapping="Wrap" />
                                        <Button
                                            Grid.Column="2"
                                            Margin="12,0,0,0"
                                            Command="{Binding DownloadVoiceCommand}"
                                            Content="{Binding DownloadButtonText}"
                                            Style="{StaticResource PrimaryButton}" />
                                    </Grid>
                                    <!--  Downloading: status line + progress bar.  -->
                                    <StackPanel Visibility="{Binding IsDownloading, Converter={StaticResource BoolToVis}}">
                                        <TextBlock Foreground="{StaticResource TextPrimary}" Text="{Binding DownloadStatusText}" />
                                        <ProgressBar
                                            Margin="0,8,0,0"
                                            Maximum="100"
                                            Style="{StaticResource ThinProgress}"
                                            Value="{Binding DownloadProgress}" />
                                    </StackPanel>
                                    <!--  Done: brief success confirmation before the strip collapses.  -->
                                    <StackPanel Orientation="Horizontal" Visibility="{Binding DownloadJustCompleted, Converter={StaticResource BoolToVis}}">
                                        <TextBlock
                                            Margin="0,0,10,0"
                                            VerticalAlignment="Center"
                                            FontFamily="{StaticResource IconFont}"
                                            FontSize="16"
                                            Foreground="{StaticResource StatusOnline}"
                                            Text="{StaticResource Icon.CheckCircle}" />
                                        <TextBlock
                                            VerticalAlignment="Center"
                                            Foreground="{StaticResource TextPrimary}"
                                            Text="{Binding DownloadDoneText}" />
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <HeaderedContentControl Style="{StaticResource SettingsCard}" Tag="{StaticResource Icon.Speed}">
                                <HeaderedContentControl.Header>
                                    <StackPanel>
                                        <TextBlock Style="{StaticResource CardTitle}" Text="{Binding TtsSpeed, StringFormat='Speed: {0}'}" />
                                        <TextBlock Style="{StaticResource CardDesc}" Text="Volume is set under Sound › Auto-level." />
                                    </StackPanel>
                                </HeaderedContentControl.Header>
                                <Slider
                                    Width="200"
                                    Maximum="20"
                                    Minimum="0"
                                    Value="{Binding TtsSpeed}" />
                            </HeaderedContentControl>
                        </StackPanel>

                        <!--  Test — shared by both engines; gated on being in a voice channel with a ready voice.  -->
                        <HeaderedContentControl Style="{StaticResource SettingsCard}" Tag="{StaticResource Icon.PlayCircle}">
                            <HeaderedContentControl.Header>
                                <StackPanel>
                                    <TextBlock Style="{StaticResource CardTitle}" Text="Test voice" />
                                    <TextBlock Style="{StaticResource CardDesc}" Text="Plays a sample line through the bot." />
                                </StackPanel>
                            </HeaderedContentControl.Header>
                            <StackPanel Orientation="Horizontal">
                                <Button
                                    MinWidth="96"
                                    Command="{Binding TestCommand}"
                                    Content="▶ Test"
                                    Style="{StaticResource PrimaryButton}" />
                                <ToggleButton
                                    x:Name="TestHelp"
                                    Margin="6,0,0,0"
                                    Style="{StaticResource HelpGlyphButton}" />
                                <Popup
                                    AllowsTransparency="True"
                                    IsOpen="{Binding IsChecked, ElementName=TestHelp}"
                                    Placement="Bottom"
                                    PlacementTarget="{Binding ElementName=TestHelp}"
                                    StaysOpen="False">
                                    <Border
                                        MaxWidth="260"
                                        Margin="0,6,8,8"
                                        Padding="12,10"
                                        Background="{StaticResource Card}"
                                        BorderBrush="{StaticResource CardBorder}"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        Effect="{StaticResource FlyoutShadow}">
                                        <TextBlock
                                            Foreground="{StaticResource TextSecondary}"
                                            Text="Test plays through the bot. Connect and join a voice channel on the General page first."
                                            TextWrapping="Wrap" />
                                    </Border>
                                </Popup>
                            </StackPanel>
                        </HeaderedContentControl>

                        <!--  Advanced — ONNX-only, collapsed by default (CPU threads · models folder).  -->
                        <StackPanel Visibility="{Binding IsOnnx, Converter={StaticResource BoolToVis}}">
                            <ToggleButton
                                Margin="0,10,0,0"
                                Checked="OnAdvancedExpanded"
                                Content="Advanced"
                                IsChecked="{Binding IsAdvancedExpanded, Mode=TwoWay}"
                                Style="{StaticResource DisclosureToggle}" />

                            <StackPanel Margin="0,4,0,0" Visibility="{Binding IsAdvancedExpanded, Converter={StaticResource BoolToVis}}">
                                <HeaderedContentControl Style="{StaticResource SettingsCard}">
                                    <HeaderedContentControl.Header>
                                        <StackPanel>
                                            <TextBlock Style="{StaticResource CardTitle}" Text="CPU usage" />
                                            <TextBlock Style="{StaticResource CardDesc}" Text="Low is gentlest while gaming." />
                                        </StackPanel>
                                    </HeaderedContentControl.Header>
                                    <Border Style="{StaticResource Segmented}">
                                        <StackPanel Orientation="Horizontal">
                                            <RadioButton
                                                Content="Low · 1"
                                                GroupName="threads"
                                                IsChecked="{Binding IsThreads1, Mode=TwoWay}"
                                                Style="{StaticResource SegmentButton}" />
                                            <RadioButton
                                                Content="Balanced · 2"
                                                GroupName="threads"
                                                IsChecked="{Binding IsThreads2, Mode=TwoWay}"
                                                Style="{StaticResource SegmentButton}" />
                                            <RadioButton
                                                Content="Fast · 4"
                                                GroupName="threads"
                                                IsChecked="{Binding IsThreads4, Mode=TwoWay}"
                                                Style="{StaticResource SegmentButton}" />
                                        </StackPanel>
                                    </Border>
                                </HeaderedContentControl>

                                <HeaderedContentControl Style="{StaticResource SettingsCard}">
                                    <HeaderedContentControl.Header>
                                        <StackPanel>
                                            <TextBlock Style="{StaticResource CardTitle}" Text="Models folder" />
                                            <TextBlock Style="{StaticResource CardDesc}" Text="Where downloaded voices are stored." />
                                        </StackPanel>
                                    </HeaderedContentControl.Header>
                                    <StackPanel>
                                        <Button
                                            HorizontalAlignment="Left"
                                            Click="OnBrowseModelsFolder"
                                            Content="Pick a folder" />
                                        <TextBlock
                                            Margin="0,8,0,0"
                                            Foreground="{StaticResource TextMuted}"
                                            Text="{Binding ModelsDir}"
                                            TextTrimming="CharacterEllipsis"
                                            ToolTip="{Binding ModelsDir}" />
                                    </StackPanel>
                                </HeaderedContentControl>
                            </StackPanel>
                        </StackPanel>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!--  ===== Sound =====  -->
            <TabItem Header="Sound" Tag="{StaticResource Icon.Sound}">
                <ScrollViewer Padding="20,16" VerticalScrollBarVisibility="Auto">
                    <StackPanel MaxWidth="640">

                        <TextBlock
                            Margin="2,0,0,8"
                            Style="{StaticResource SectionHeader}"
                            Text="Effects &amp; leveling" />

                        <HeaderedContentControl Style="{StaticResource SettingsCard}" Tag="{StaticResource Icon.Wand}">
                            <HeaderedContentControl.Header>
                                <StackPanel>
                                    <TextBlock Style="{StaticResource CardTitle}" Text="Random sound effects" />
                                    <TextBlock Style="{StaticResource CardDesc}" Text="Occasionally play a random effect." />
                                </StackPanel>
                            </HeaderedContentControl.Header>
                            <CheckBox IsChecked="{Binding RandomFx}" Style="{StaticResource ToggleSwitch}" />
                        </HeaderedContentControl>

                        <HeaderedContentControl Header="{Binding FxChanceLabel}" Style="{StaticResource SettingsCard}">
                            <Slider
                                Width="200"
                                Maximum="100"
                                Minimum="0"
                                Value="{Binding FxChance}" />
                        </HeaderedContentControl>

                        <HeaderedContentControl Style="{StaticResource SettingsCard}" Tag="{StaticResource Icon.Level}">
                            <HeaderedContentControl.Header>
                                <StackPanel>
                                    <TextBlock Style="{StaticResource CardTitle}" Text="Auto-level volume" />
                                    <TextBlock Style="{StaticResource CardDesc}" Text="Even out loud and quiet sounds." />
                                </StackPanel>
                            </HeaderedContentControl.Header>
                            <CheckBox IsChecked="{Binding Normalize}" Style="{StaticResource ToggleSwitch}" />
                        </HeaderedContentControl>

                        <HeaderedContentControl Header="{Binding NormalizeTargetLabel}" Style="{StaticResource SettingsCard}">
                            <Slider
                                Width="200"
                                Maximum="30"
                                Minimum="12"
                                Value="{Binding NormalizeTarget}" />
                        </HeaderedContentControl>

                        <HeaderedContentControl Style="{StaticResource SettingsCard}" Tag="{StaticResource Icon.TopSpeed}">
                            <HeaderedContentControl.Header>
                                <StackPanel>
                                    <TextBlock Style="{StaticResource CardTitle}" Text="Master limiter" />
                                    <TextBlock Style="{StaticResource CardDesc}" Text="Stop overlapping sounds from clipping." />
                                </StackPanel>
                            </HeaderedContentControl.Header>
                            <CheckBox IsChecked="{Binding LimiterEnabled}" Style="{StaticResource ToggleSwitch}" />
                        </HeaderedContentControl>

                        <HeaderedContentControl
                            Header="Limiter ceiling"
                            IsEnabled="{Binding LimiterEnabled}"
                            Style="{StaticResource SettingsCard}">
                            <ComboBox Width="220" SelectedIndex="{Binding LimiterCeilingIndex}">
                                <ComboBoxItem>-0.5 dB</ComboBoxItem>
                                <ComboBoxItem>-1 dB (recommended)</ComboBoxItem>
                                <ComboBoxItem>-2 dB</ComboBoxItem>
                                <ComboBoxItem>-3 dB</ComboBoxItem>
                            </ComboBox>
                        </HeaderedContentControl>

                        <HeaderedContentControl
                            Header="Audio quality"
                            Style="{StaticResource SettingsCard}"
                            Tag="{StaticResource Icon.Quality}">
                            <ComboBox Width="220" SelectedIndex="{Binding AudioQualityIndex}">
                                <ComboBoxItem>Low (48 kbps)</ComboBoxItem>
                                <ComboBoxItem>Medium (96 kbps)</ComboBoxItem>
                                <ComboBoxItem>High (128 kbps)</ComboBoxItem>
                            </ComboBox>
                        </HeaderedContentControl>

                        <Border Style="{StaticResource InfoCallout}" Visibility="{Binding ShowHighQualityWarning, Converter={StaticResource BoolToVis}}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock
                                    Margin="0,1,10,0"
                                    VerticalAlignment="Top"
                                    Foreground="{StaticResource Accent}"
                                    Style="{StaticResource IconGlyph}"
                                    Text="{StaticResource Icon.Info}" />
                                <TextBlock
                                    MaxWidth="460"
                                    Foreground="{StaticResource TextPrimary}"
                                    Text="High quality needs a Discord channel that supports 128 kbps (a boosted server)."
                                    TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!--  ===== Information =====  -->
            <TabItem Header="Information" Tag="{StaticResource Icon.Info}">
                <ScrollViewer Padding="20,16" VerticalScrollBarVisibility="Auto">
                    <StackPanel MaxWidth="520" HorizontalAlignment="Center">
                        <Image
                            Width="104"
                            Height="104"
                            Margin="0,8,0,10"
                            HorizontalAlignment="Center"
                            Source="pack://application:,,,/ACT_DiscordTriggers;component/logo.png" />
                        <TextBlock
                            HorizontalAlignment="Center"
                            FontFamily="Segoe UI Variable Display, Segoe UI"
                            FontSize="20"
                            FontWeight="SemiBold"
                            Foreground="{StaticResource TextPrimary}"
                            LineHeight="28"
                            Text="ACT Discord Triggers" />
                        <TextBlock
                            Margin="0,2,0,10"
                            HorizontalAlignment="Center"
                            Foreground="{StaticResource TextMuted}"
                            Text="{x:Static local:DiscordTriggersPlugin.VersionDisplay}" />
                        <TextBlock
                            Margin="0,0,0,4"
                            Foreground="{StaticResource TextSecondary}"
                            LineHeight="20"
                            Text="Play your ACT triggers — text-to-speech and sound effects — through a Discord voice bot, so your whole party hears them."
                            TextAlignment="Center"
                            TextWrapping="Wrap" />

                        <Border
                            Height="1"
                            Margin="0,16"
                            Background="{StaticResource Divider}" />

                        <StackPanel Margin="0,0,0,4" HorizontalAlignment="Center">
                            <StackPanel Margin="0,3" Orientation="Horizontal">
                                <TextBlock
                                    Margin="0,0,9,0"
                                    VerticalAlignment="Center"
                                    FontFamily="{StaticResource IconFont}"
                                    FontSize="16"
                                    Foreground="{StaticResource Accent}"
                                    Text="{StaticResource Icon.Open}" />
                                <TextBlock VerticalAlignment="Center" Foreground="{StaticResource Accent}">
                                    <Hyperlink Foreground="{StaticResource Accent}" NavigateUri="https://github.com/jlagedo/ACT-Discord-Triggers">
                                        <i:Interaction.Triggers>
                                            <i:EventTrigger EventName="RequestNavigate">
                                                <i:LaunchUriOrFileAction Path="https://github.com/jlagedo/ACT-Discord-Triggers" />
                                            </i:EventTrigger>
                                        </i:Interaction.Triggers>
                                        Project on GitHub
                                    </Hyperlink>
                                </TextBlock>
                            </StackPanel>
                            <StackPanel Margin="0,3" Orientation="Horizontal">
                                <TextBlock
                                    Margin="0,0,9,0"
                                    VerticalAlignment="Center"
                                    FontFamily="{StaticResource IconFont}"
                                    FontSize="16"
                                    Foreground="{StaticResource Accent}"
                                    Text="{StaticResource Icon.Bug}" />
                                <TextBlock VerticalAlignment="Center" Foreground="{StaticResource Accent}">
                                    <Hyperlink Foreground="{StaticResource Accent}" NavigateUri="https://github.com/jlagedo/ACT-Discord-Triggers/issues/new">
                                        <i:Interaction.Triggers>
                                            <i:EventTrigger EventName="RequestNavigate">
                                                <i:LaunchUriOrFileAction Path="https://github.com/jlagedo/ACT-Discord-Triggers/issues/new" />
                                            </i:EventTrigger>
                                        </i:Interaction.Triggers>
                                        Report a problem
                                    </Hyperlink>
                                </TextBlock>
                            </StackPanel>
                            <StackPanel Margin="0,3" Orientation="Horizontal">
                                <TextBlock
                                    Margin="0,0,9,0"
                                    VerticalAlignment="Center"
                                    FontFamily="{StaticResource IconFont}"
                                    FontSize="16"
                                    Foreground="{StaticResource Accent}"
                                    Text="{StaticResource Icon.Guide}" />
                                <TextBlock VerticalAlignment="Center" Foreground="{StaticResource Accent}">
                                    <Hyperlink Foreground="{StaticResource Accent}" NavigateUri="https://github.com/jlagedo/ACT-Discord-Triggers/wiki/First-Time-Setup-Guide">
                                        <i:Interaction.Triggers>
                                            <i:EventTrigger EventName="RequestNavigate">
                                                <i:LaunchUriOrFileAction Path="https://github.com/jlagedo/ACT-Discord-Triggers/wiki/First-Time-Setup-Guide" />
                                            </i:EventTrigger>
                                        </i:Interaction.Triggers>
                                        First-time setup guide
                                    </Hyperlink>
                                </TextBlock>
                            </StackPanel>
                        </StackPanel>

                        <Border
                            Height="1"
                            Margin="0,16"
                            Background="{StaticResource Divider}" />

                        <TextBlock
                            Margin="0,0,0,10"
                            Foreground="{StaticResource TextSecondary}"
                            Text="Hit a bug? Open the diagnostics log and attach it to your report."
                            TextAlignment="Center"
                            TextWrapping="Wrap" />
                        <Button
                            Margin="0,0,0,4"
                            HorizontalAlignment="Center"
                            Command="{Binding OpenLogFolderCommand}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock
                                    Margin="0,0,8,0"
                                    VerticalAlignment="Center"
                                    FontFamily="{StaticResource IconFont}"
                                    FontSize="16"
                                    Foreground="{StaticResource TextPrimary}"
                                    Text="{StaticResource Icon.Folder}" />
                                <TextBlock VerticalAlignment="Center" Text="Open log folder" />
                            </StackPanel>
                        </Button>

                        <Border
                            Height="1"
                            Margin="0,16"
                            Background="{StaticResource Divider}" />

                        <TextBlock
                            Margin="0,2,0,0"
                            FontSize="11"
                            Foreground="{StaticResource TextMuted}"
                            Text="ACT Discord Triggers is a community plugin — not affiliated with or endorsed by Discord, Square Enix, or Advanced Combat Tracker. Provided as-is under the MIT License, without warranty; use at your own risk and follow Discord's Terms of Service. Originally created by Makar8000."
                            TextAlignment="Center"
                            TextWrapping="Wrap" />
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

        </TabControl>
    </DockPanel>
</UserControl>
