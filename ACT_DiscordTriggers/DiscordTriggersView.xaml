<UserControl
    x:Class="ACT_DiscordTriggers.DiscordTriggersView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
    xmlns:local="clr-namespace:ACT_DiscordTriggers"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="730"
    d:DesignWidth="760"
    FontFamily="Segoe UI"
    FontSize="13"
    mc:Ignorable="d">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <Thickness x:Key="FieldMargin">0,4,0,10</Thickness>
    </UserControl.Resources>

    <DockPanel LastChildFill="True">

        <!--  Debug log: docked at the bottom across the full width.  -->
        <DockPanel
            Height="210"
            Margin="6"
            DockPanel.Dock="Bottom">
            <TextBlock
                Margin="2,0,0,4"
                DockPanel.Dock="Top"
                Text="Debug Log" />
            <ListView
                local:LogListCopy.Enabled="True"
                ItemsSource="{Binding LogEntries}"
                SelectionMode="Extended">
                <ListView.View>
                    <GridView>
                        <GridViewColumn
                            Width="160"
                            DisplayMemberBinding="{Binding Timestamp, StringFormat='{}{0:G}'}"
                            Header="Timestamp" />
                        <GridViewColumn
                            Width="540"
                            DisplayMemberBinding="{Binding Message}"
                            Header="Message" />
                    </GridView>
                </ListView.View>
            </ListView>
        </DockPanel>

        <!--  Left-rail navigation (General / Sound / Information) over the remaining area.  -->
        <TabControl Margin="6,6,6,0" TabStripPlacement="Left">

            <!--  ===== General =====  -->
            <TabItem Header="General">
                <ScrollViewer Padding="10" VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <GroupBox
                            Margin="0,0,0,10"
                            Padding="10"
                            Header="Discord Connection">
                            <StackPanel>
                                <TextBlock Text="Discord Bot Token" />
                                <PasswordBox
                                    MaxWidth="340"
                                    Margin="{StaticResource FieldMargin}"
                                    HorizontalAlignment="Left"
                                    local:PasswordBoxBinding.BoundPassword="{Binding BotToken, UpdateSourceTrigger=PropertyChanged}" />
                                <StackPanel Margin="0,0,0,10" Orientation="Horizontal">
                                    <Button
                                        Width="140"
                                        Height="32"
                                        Command="{Binding ConnectCommand}"
                                        Content="Connect" />
                                    <CheckBox
                                        Margin="16,0,0,0"
                                        VerticalAlignment="Center"
                                        Content="Auto Connect"
                                        IsChecked="{Binding AutoConnect}" />
                                </StackPanel>
                                <TextBlock Text="Bot Status" />
                                <TextBox
                                    MaxWidth="340"
                                    Margin="{StaticResource FieldMargin}"
                                    HorizontalAlignment="Left"
                                    Text="{Binding BotStatus, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                        </GroupBox>

                        <GroupBox Padding="10" Header="Voice Channel">
                            <StackPanel>
                                <TextBlock Text="Server" />
                                <ComboBox
                                    MaxWidth="340"
                                    Margin="{StaticResource FieldMargin}"
                                    HorizontalAlignment="Left"
                                    ItemsSource="{Binding Servers}"
                                    SelectedItem="{Binding SelectedServer}" />
                                <TextBlock Text="Channel" />
                                <ComboBox
                                    MaxWidth="340"
                                    Margin="{StaticResource FieldMargin}"
                                    HorizontalAlignment="Left"
                                    ItemsSource="{Binding Channels}"
                                    SelectedItem="{Binding SelectedChannel}" />
                                <StackPanel Orientation="Horizontal">
                                    <Button
                                        Width="140"
                                        Height="32"
                                        Command="{Binding JoinCommand}"
                                        Content="Join Channel" />
                                    <Button
                                        Width="140"
                                        Height="32"
                                        Margin="12,0,0,0"
                                        Command="{Binding LeaveCommand}"
                                        Content="Leave Channel" />
                                </StackPanel>
                            </StackPanel>
                        </GroupBox>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!--  ===== Sound =====  -->
            <TabItem Header="Sound">
                <ScrollViewer Padding="10" VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <GroupBox
                            Margin="0,0,0,10"
                            Padding="10"
                            Header="Text-to-Speech">
                            <StackPanel>
                                <TextBlock Text="TTS Voice" />
                                <ComboBox
                                    MaxWidth="340"
                                    Margin="{StaticResource FieldMargin}"
                                    HorizontalAlignment="Left"
                                    ItemsSource="{Binding Voices}"
                                    SelectedItem="{Binding TtsVoice}" />
                                <TextBlock Text="TTS Volume" />
                                <Slider
                                    Width="320"
                                    Margin="{StaticResource FieldMargin}"
                                    HorizontalAlignment="Left"
                                    Maximum="20"
                                    Minimum="0"
                                    Value="{Binding TtsVolume}" />
                                <TextBlock Text="TTS Speed" />
                                <Slider
                                    Width="320"
                                    Margin="{StaticResource FieldMargin}"
                                    HorizontalAlignment="Left"
                                    Maximum="20"
                                    Minimum="0"
                                    Value="{Binding TtsSpeed}" />
                            </StackPanel>
                        </GroupBox>

                        <GroupBox Padding="10" Header="Effects &amp; Leveling">
                            <StackPanel>
                                <CheckBox
                                    Margin="0,0,0,8"
                                    Content="Random Sound FX"
                                    IsChecked="{Binding RandomFx}" />
                                <TextBlock Text="{Binding FxChanceLabel}" />
                                <Slider
                                    Width="320"
                                    Margin="{StaticResource FieldMargin}"
                                    HorizontalAlignment="Left"
                                    Maximum="100"
                                    Minimum="0"
                                    Value="{Binding FxChance}" />
                                <CheckBox
                                    Margin="0,0,0,8"
                                    Content="Auto-level Volume"
                                    IsChecked="{Binding Normalize}" />
                                <TextBlock Text="{Binding NormalizeTargetLabel}" />
                                <Slider
                                    Width="320"
                                    Margin="{StaticResource FieldMargin}"
                                    HorizontalAlignment="Left"
                                    Maximum="30"
                                    Minimum="12"
                                    Value="{Binding NormalizeTarget}" />
                                <TextBlock Text="Audio Quality" />
                                <ComboBox
                                    Width="200"
                                    Margin="{StaticResource FieldMargin}"
                                    HorizontalAlignment="Left"
                                    SelectedIndex="{Binding AudioQualityIndex}">
                                    <ComboBoxItem>Low (48 kbps)</ComboBoxItem>
                                    <ComboBoxItem>Medium (96 kbps)</ComboBoxItem>
                                    <ComboBoxItem>High (128 kbps)</ComboBoxItem>
                                </ComboBox>
                                <TextBlock
                                    Foreground="Firebrick"
                                    Text="High needs a Discord channel that supports 128 kbps (boosted server)."
                                    TextWrapping="Wrap"
                                    Visibility="{Binding ShowHighQualityWarning, Converter={StaticResource BoolToVis}}" />
                            </StackPanel>
                        </GroupBox>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!--  ===== Information =====  -->
            <TabItem Header="Information">
                <ScrollViewer Padding="10" VerticalScrollBarVisibility="Auto">
                    <StackPanel MaxWidth="560" HorizontalAlignment="Center">
                        <Image
                            Width="112"
                            Height="112"
                            Margin="0,8,0,6"
                            HorizontalAlignment="Center"
                            Source="pack://application:,,,/ACT_DiscordTriggers;component/logo.png" />
                        <TextBlock
                            HorizontalAlignment="Center"
                            FontSize="20"
                            FontWeight="Bold"
                            Text="ACT Discord Triggers" />
                        <TextBlock
                            Margin="0,0,0,8"
                            HorizontalAlignment="Center"
                            Foreground="Gray"
                            Text="{x:Static local:DiscordTriggersPlugin.VersionDisplay}" />
                        <TextBlock
                            Margin="0,0,0,12"
                            Text="Play your ACT triggers — text-to-speech and sound effects — through a Discord voice bot, so your whole party hears them."
                            TextAlignment="Center"
                            TextWrapping="Wrap" />

                        <Separator Margin="20,8" />

                        <StackPanel Margin="0,0,0,12" HorizontalAlignment="Center">
                            <TextBlock Margin="0,2">
                                <Hyperlink NavigateUri="https://github.com/jlagedo/ACT-Discord-Triggers">
                                    <i:Interaction.Triggers>
                                        <i:EventTrigger EventName="RequestNavigate">
                                            <i:LaunchUriOrFileAction Path="https://github.com/jlagedo/ACT-Discord-Triggers" />
                                        </i:EventTrigger>
                                    </i:Interaction.Triggers>
                                    ↗  Project on GitHub
                                </Hyperlink>
                            </TextBlock>
                            <TextBlock Margin="0,2">
                                <Hyperlink NavigateUri="https://github.com/jlagedo/ACT-Discord-Triggers/issues/new">
                                    <i:Interaction.Triggers>
                                        <i:EventTrigger EventName="RequestNavigate">
                                            <i:LaunchUriOrFileAction Path="https://github.com/jlagedo/ACT-Discord-Triggers/issues/new" />
                                        </i:EventTrigger>
                                    </i:Interaction.Triggers>
                                    ↗  Report a problem / open an issue
                                </Hyperlink>
                            </TextBlock>
                            <TextBlock Margin="0,2">
                                <Hyperlink NavigateUri="https://github.com/jlagedo/ACT-Discord-Triggers/wiki/First-Time-Setup-Guide">
                                    <i:Interaction.Triggers>
                                        <i:EventTrigger EventName="RequestNavigate">
                                            <i:LaunchUriOrFileAction Path="https://github.com/jlagedo/ACT-Discord-Triggers/wiki/First-Time-Setup-Guide" />
                                        </i:EventTrigger>
                                    </i:Interaction.Triggers>
                                    ↗  First-Time Setup Guide
                                </Hyperlink>
                            </TextBlock>
                        </StackPanel>

                        <Separator Margin="20,8" />

                        <TextBlock
                            Margin="0,0,0,4"
                            Foreground="Gray"
                            Text="Hit a bug? Open the diagnostics log and attach it to your report."
                            TextAlignment="Center"
                            TextWrapping="Wrap" />
                        <Button
                            Margin="0,0,0,12"
                            Padding="10,3"
                            HorizontalAlignment="Center"
                            Command="{Binding OpenLogFolderCommand}"
                            Content="Open log folder" />

                        <Separator Margin="20,8" />

                        <TextBlock
                            Margin="0,6,0,0"
                            FontSize="11"
                            Foreground="Gray"
                            Text="ACT Discord Triggers is a community plugin — not affiliated with or endorsed by Discord, Square Enix, or Advanced Combat Tracker. Provided as-is under the MIT License, without warranty; use at your own risk and follow Discord's Terms of Service. Originally created by Makar8000."
                            TextAlignment="Center"
                            TextWrapping="Wrap" />
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

        </TabControl>
    </DockPanel>
</UserControl>
