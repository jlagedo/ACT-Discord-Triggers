<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net48</TargetFramework>
    <IsPackable>false</IsPackable>
    <LangVersion>latest</LangVersion>
    <Nullable>disable</Nullable>
  </PropertyGroup>
  <ItemGroup>
    <!-- xunit 2.x line: xunit 2.9.x and xunit.runner.visualstudio 2.8.x both ship
         net4x targets. xunit.runner.visualstudio 3.x dropped Framework support. -->
    <PackageReference Include="Microsoft.NET.Test.Sdk" Version="18.6.0" />
    <PackageReference Include="xunit" Version="2.9.3" />
    <PackageReference Include="xunit.runner.visualstudio" Version="2.8.2">
      <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
      <PrivateAssets>all</PrivateAssets>
    </PackageReference>
    <!-- The plugin references System.Text.Json 10.0.9 on net48 already; match
         it here so the linked source files use the same JSON types. -->
    <PackageReference Include="System.Text.Json" Version="10.0.9" />
    <!-- The linked ViewModel uses CommunityToolkit.Mvvm; the source generators must
         run over it here too. Match the plugin's version. -->
    <PackageReference Include="CommunityToolkit.Mvvm" Version="8.4.0" />
  </ItemGroup>
  <ItemGroup>
    <None Include="xunit.runner.json" CopyToOutputDirectory="PreserveNewest" />
    <Compile Include="..\ACT_DiscordTriggers\Protocol\Protocol.cs" Link="Protocol.cs" />
    <Compile Include="..\ACT_DiscordTriggers\Ipc\DiagnosticsLog.cs" Link="DiagnosticsLog.cs" />
    <Compile Include="..\ACT_DiscordTriggers\Ipc\PipeClient.cs" Link="PipeClient.cs" />
    <Compile Include="..\ACT_DiscordTriggers\Ipc\BridgeProcess.cs" Link="BridgeProcess.cs" />
    <!-- Settings POCO + migration framework: pure C# (no WinForms/ACT), linked in
         so they can be unit-tested without referencing the plugin assembly. -->
    <Compile Include="..\ACT_DiscordTriggers\Settings\PluginSettings.cs" Link="Settings\PluginSettings.cs" />
    <Compile Include="..\ACT_DiscordTriggers\Settings\SettingsStore.cs" Link="Settings\SettingsStore.cs" />
    <Compile Include="..\ACT_DiscordTriggers\Settings\LegacyConfigImporter.cs" Link="Settings\LegacyConfigImporter.cs" />
    <Compile Include="..\ACT_DiscordTriggers\Settings\Migrations\ISettingsMigration.cs" Link="Settings\Migrations\ISettingsMigration.cs" />
    <Compile Include="..\ACT_DiscordTriggers\Settings\Migrations\SettingsMigrator.cs" Link="Settings\Migrations\SettingsMigrator.cs" />
    <Compile Include="..\ACT_DiscordTriggers\Settings\Migrations\SettingsMigrationException.cs" Link="Settings\Migrations\SettingsMigrationException.cs" />
    <!-- ViewModel layer: UI-agnostic (no WinForms/ACT), linked in so it can be
         unit-tested with a fake IDiscordService. -->
    <Compile Include="..\ACT_DiscordTriggers\Ipc\IDiscordService.cs" Link="Ipc\IDiscordService.cs" />
    <Compile Include="..\ACT_DiscordTriggers\ViewModels\LogEntry.cs" Link="ViewModels\LogEntry.cs" />
    <Compile Include="..\ACT_DiscordTriggers\ViewModels\DiscordTriggersViewModel.cs" Link="ViewModels\DiscordTriggersViewModel.cs" />
  </ItemGroup>
</Project>
